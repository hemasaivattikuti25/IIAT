---
import Layout from '../layouts/Layout.astro';
---

<Layout title="IIAT Hyderabad | Where Curiosity Becomes Capability">

  <!-- ===== HERO ===== -->
  <section class="bg-white pt-28 pb-20 px-6 border-b-2 border-[#21275a]/10">
    <div class="max-w-6xl mx-auto flex flex-col items-center text-center gap-8">
      <span class="inline-block px-5 py-2 rounded-full bg-[#f7ba26]/20 text-[#21275a] text-sm font-bold tracking-wide uppercase">
        India's Most Industry-Integrated B.Tech
      </span>
      <h1 class="text-5xl md:text-7xl font-extrabold text-[#21275a] leading-tight tracking-tight">
        Where Curiosity<br class="hidden md:block"/> Becomes <span class="text-[#b00f1e]">Capability</span>
      </h1>
      <p class="text-xl md:text-2xl text-[#21275a] font-medium max-w-3xl">
        India's Most Industry-Integrated B.Tech Program
      </p>
      <a href="#apply"
        class="inline-flex items-center justify-center px-10 py-5 bg-[#b00f1e] text-white text-lg font-bold rounded-xl hover:bg-[#8a0c17] transition-colors">
        Register for ROGER SAT — Free | No JEE Required
      </a>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <section class="bg-white py-16 px-6 border-b-2 border-[#21275a]/10">
    <div class="max-w-6xl mx-auto grid grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 text-center">
        <div class="text-5xl font-extrabold text-[#b00f1e] mb-2">500+</div>
        <div class="text-[#21275a] font-semibold text-lg">Students Enrolled</div>
      </div>
      <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 text-center">
        <div class="text-5xl font-extrabold text-[#b00f1e] mb-2">6</div>
        <div class="text-[#21275a] font-semibold text-lg">Specialized Programs</div>
      </div>
      <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 text-center">
        <div class="text-5xl font-extrabold text-[#b00f1e] mb-2">100%</div>
        <div class="text-[#21275a] font-semibold text-lg">Industry-Integrated Curriculum</div>
      </div>
      <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 text-center">
        <div class="text-5xl font-extrabold text-[#b00f1e] mb-2">4 Year</div>
        <div class="text-[#21275a] font-semibold text-lg">Professional B.Tech Degree</div>
      </div>
    </div>
  </section>

  <!-- ===== PROGRAMS ===== -->
  <section id="programs" class="bg-white py-24 px-6 border-b-2 border-[#21275a]/10">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-4xl md:text-5xl font-extrabold text-[#21275a] mb-4">Our B.Tech Programs</h2>
        <div class="w-20 h-1.5 bg-[#f7ba26] mx-auto rounded-full"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">

        <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 flex flex-col bg-white hover:border-[#b00f1e] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#b00f1e]/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[#b00f1e]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-[#21275a] mb-1">B.Tech CSE</h3>
          <p class="text-[#b00f1e] font-bold text-lg mb-6">(AI & Data Science)</p>
          <div class="mt-auto">
            <span class="inline-block px-4 py-2 bg-[#f7ba26]/20 text-[#21275a] font-bold rounded-lg text-sm">180 Seats</span>
          </div>
        </div>

        <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 flex flex-col bg-white hover:border-[#b00f1e] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#b00f1e]/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[#b00f1e]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-[#21275a] mb-1">B.Tech CSE</h3>
          <p class="text-[#b00f1e] font-bold text-lg mb-6">(FinTech & Artificial Intelligence)</p>
          <div class="mt-auto">
            <span class="inline-block px-4 py-2 bg-[#f7ba26]/20 text-[#21275a] font-bold rounded-lg text-sm">60 Seats</span>
          </div>
        </div>

        <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 flex flex-col bg-white hover:border-[#b00f1e] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#b00f1e]/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[#b00f1e]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-[#21275a] mb-1">B.Tech CSE</h3>
          <p class="text-[#b00f1e] font-bold text-lg mb-6">(Core)</p>
          <div class="mt-auto">
            <span class="inline-block px-4 py-2 bg-[#f7ba26]/20 text-[#21275a] font-bold rounded-lg text-sm">180 Seats</span>
          </div>
        </div>

        <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 flex flex-col bg-white hover:border-[#b00f1e] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#b00f1e]/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[#b00f1e]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-[#21275a] mb-1">B.Tech CSE</h3>
          <p class="text-[#b00f1e] font-bold text-lg mb-6">(AI & Machine Learning)</p>
          <div class="mt-auto">
            <span class="inline-block px-4 py-2 bg-[#f7ba26]/20 text-[#21275a] font-bold rounded-lg text-sm">180 Seats</span>
          </div>
        </div>

        <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 flex flex-col bg-white hover:border-[#b00f1e] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#b00f1e]/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[#b00f1e]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-[#21275a] mb-1">B.Tech CSE</h3>
          <p class="text-[#b00f1e] font-bold text-lg mb-6">(Cyber Security with AI/ML)</p>
          <div class="mt-auto">
            <span class="inline-block px-4 py-2 bg-[#f7ba26]/20 text-[#21275a] font-bold rounded-lg text-sm">60 Seats</span>
          </div>
        </div>

        <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 flex flex-col bg-white hover:border-[#b00f1e] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#b00f1e]/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-[#b00f1e]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
          </div>
          <h3 class="text-xl font-bold text-[#21275a] mb-1">B.Tech</h3>
          <p class="text-[#b00f1e] font-bold text-lg mb-6">(Biomedical Engineering, AI & Medical Robotics)</p>
          <div class="mt-auto">
            <span class="inline-block px-4 py-2 bg-[#f7ba26]/20 text-[#21275a] font-bold rounded-lg text-sm">60 Seats</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ===== CAMPUS ===== -->
  <section class="bg-white py-24 px-6 border-b-2 border-[#21275a]/10">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-extrabold text-[#21275a] mb-4">Experience Life at Campus</h2>
      <div class="w-20 h-1.5 bg-[#f7ba26] mx-auto rounded-full mb-10"></div>
      <p class="text-xl text-[#21275a] max-w-4xl mx-auto mb-12 leading-relaxed">
        Our campus provides a thriving, state-of-the-art ecosystem for technology
        enthusiasts — with advanced labs, industry centres of excellence, and a highly
        collaborative environment that prepares you for tomorrow.
      </p>
      <a href="/campus-life"
        class="inline-flex px-10 py-5 border-2 border-[#b00f1e] text-[#b00f1e] text-lg font-bold rounded-xl hover:bg-[#b00f1e] hover:text-white transition-colors">
        Explore Campus Life
      </a>
    </div>
  </section>

  <!-- ===== APPLY CTA ===== -->
  <section id="apply" class="bg-[#21275a] py-20 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6">Ready to Begin?</h2>
      <p class="text-xl text-gray-300 mb-10">Join IIAT Hyderabad — No JEE Required. Register for a free ROGER SAT and secure your seat.</p>
      <a href="mailto:info@iiath.com"
        class="inline-flex px-12 py-5 bg-[#f7ba26] text-[#21275a] text-lg font-extrabold rounded-xl hover:bg-[#fccf46] transition-colors">
        Apply Now — info@iiath.com
      </a>
    </div>
  </section>

  <!-- ===== FOOTER ===== -->
  <footer class="bg-[#21275a] pt-16 pb-8 px-6 border-t-4 border-[#b00f1e]">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

      <div>
        <h2 class="text-2xl font-extrabold text-white mb-3">IIAT Hyderabad</h2>
        <p class="text-[#f7ba26] font-semibold mb-4">Where Curiosity Becomes Capability</p>
        <p class="text-gray-300 text-sm leading-relaxed">
          Indian Institute of Advanced Technologies — Developing the next generation
          of technologists with India's most industry-integrated curriculum.
        </p>
      </div>

      <div>
        <h3 class="text-lg font-bold text-white mb-6">Quick Links</h3>
        <ul class="space-y-3 text-gray-300 text-sm">
          <li><a href="/about-us" class="hover:text-white transition-colors">About IIAT</a></li>
          <li><a href="/programs/ug" class="hover:text-white transition-colors">Programs</a></li>
          <li><a href="/campus-life" class="hover:text-white transition-colors">Campus Life</a></li>
          <li><a href="/mentors" class="hover:text-white transition-colors">Become a Mentor</a></li>
          <li><a href="/partnership" class="hover:text-white transition-colors">Partnership</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-lg font-bold text-white mb-6">Contact</h3>
        <ul class="space-y-4 text-gray-300 text-sm">
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-[#f7ba26] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498A1 1 0 0121 15.72V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            <span>+91 8688664337</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-[#f7ba26] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <span>info@iiath.com</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-[#f7ba26] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
            <span>iiath.com</span>
          </li>
        </ul>
      </div>

    </div>
    <div class="max-w-6xl mx-auto pt-8 border-t border-white/10 text-center text-[#21275a] text-sm">
      &copy; {new Date().getFullYear()} IIAT Hyderabad. All rights reserved.
    </div>
  </footer>

</Layout>
