---
import Layout from '../layouts/Layout.astro';
---

<Layout title="IIAT Hyderabad | Where Curiosity Becomes Capability">

  <!-- HERO: Full-screen video background -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Video Background -->
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay muted loop playsinline
      poster="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=1920&q=80"
    >
      <source src="https://assets.mixkit.co/videos/preview/mixkit-digital-animation-of-a-circuit-board-2436-large.mp4" type="video/mp4" />
    </video>

    <!-- Dark overlay with navy tint -->
    <div class="absolute inset-0 bg-[#21275a]/85"></div>

    <!-- Grid pattern overlay -->
    <div class="absolute inset-0" style="background-image: linear-gradient(rgba(225,29,72,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(225,29,72,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <!-- Hero Content -->
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-[#b00f1e]/10 border border-[#b00f1e]/30 text-white text-[10px] font-black uppercase tracking-[0.3em] px-8 py-3 rounded-full mb-10 backdrop-blur-md">
        <span class="w-2 h-2 bg-[#b00f1e] rounded-full animate-pulse"></span>
        India's Most Industry-Integrated B.Tech Program
      </div>

      <h1 class="text-6xl md:text-8xl lg:text-9xl font-black text-white leading-none tracking-tighter mb-8 italic">
        Where Curiosity<br/>
        <span class="text-[#f7ba26]">Becomes</span>
        <span class="text-white"> Capability</span>
      </h1>

      <p class="text-xl md:text-2xl text-white/70 font-medium max-w-3xl mx-auto mb-12 leading-relaxed">
        Indian Institute of Advanced Technologies. <br/>
        India's Most Industry-Integrated B.Tech Program.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="/register"
          class="inline-flex items-center gap-4 bg-[#b00f1e] text-white font-black uppercase tracking-widest text-sm px-12 py-5 rounded-full hover:bg-white hover:text-[#21275a] transition-all transform hover:scale-110 shadow-2xl shadow-[#b00f1e]/20">
          Register for ISAT
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/contact"
          class="inline-flex items-center gap-4 bg-white/5 backdrop-blur-xl border border-white/20 text-white font-black uppercase tracking-widest text-sm px-12 py-5 rounded-full hover:bg-white/10 transition-all">
          Download Brochure
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 group">
      <span class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20 group-hover:text-[#b00f1e] transition-colors">Scroll</span>
      <div class="w-0.5 h-12 bg-gradient-to-b from-[#b00f1e] to-transparent"></div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="bg-[#21275a] py-20 px-6 border-y border-white/5">
    <div class="max-w-7xl mx-auto grid grid-cols-2 lg:grid-cols-4 gap-12 reveal">
      {[
        { num: "500+", label: "Students Enrolled" },
        { num: "06", label: "Specialized Programs" },
        { num: "100%", label: "Industry-Integrated Curriculum" },
        { num: "4 Year", label: "Professional B.Tech Degree" },
      ].map(s => (
        <div class="text-center group">
          <div class="text-5xl lg:text-7xl font-black text-white mb-4 group-hover:text-[#f7ba26] transition-colors tabular-nums tracking-tighter">{s.num}</div>
          <div class="text-white/30 font-black text-[10px] uppercase tracking-[0.3em]">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- BEST OF BOTH WORLDS -->
  <section class="bg-white py-32 px-6 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#b00f1e]/5 blur-[120px] rounded-full translate-x-1/2 -translate-y-1/2"></div>
    <div class="max-w-6xl mx-auto relative z-10">
      <div class="text-center mb-24 reveal">
        <div class="inline-block bg-[#b00f1e]/5 text-[#b00f1e] text-[10px] font-black uppercase tracking-[0.4em] px-8 py-3 rounded-full mb-6">
          The IIAT Advantage
        </div>
        <h2 class="text-5xl md:text-7xl font-black text-[#21275a] mb-6 tracking-tighter">
          Best of Both Worlds
        </h2>
        <p class="text-[#21275a]/50 text-xl font-medium max-w-2xl mx-auto leading-relaxed">
          Combining academic rigor with industry-first skills.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 reveal">
        <!-- University Excellence -->
        <div class="bg-[#21275a] rounded-[48px] p-16 text-white relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <h3 class="text-3xl font-black mb-4 tracking-tight text-[#f7ba26]">University Excellence</h3>
            <p class="text-white/40 font-bold text-xs uppercase tracking-widest mb-12">Academic Rigor & Credential</p>
            <ul class="space-y-6">
              {[
                "UGC Approved B.Tech Degree — Recognized by UGC-MHRD, Government of India",
                "State-of-the-Art Campus — Modern infrastructure and research labs",
                "Vibrant Campus Life — Sports, clubs, events, and rich community",
                "Interdisciplinary Curriculum — CS + management + communication skills",
                "Fully Residential Campus — Live, learn, and grow in a structured environment"
              ].map(text => (
                <li class="flex items-center gap-4 group/item">
                  <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center flex-shrink-0 group-hover/item:bg-[#f7ba26]/20 transition-colors">
                    <svg class="w-5 h-5 text-[#f7ba26]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <span class="font-bold text-xs uppercase tracking-widest leading-relaxed">{text}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Industry-First Learning -->
        <div class="bg-white border border-[#21275a]/5 rounded-[48px] p-16 relative overflow-hidden group shadow-[0_40px_100px_rgba(0,0,0,0.02)]">
          <div class="absolute inset-x-0 bottom-0 h-2 bg-[#b00f1e] scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-700"></div>
          <div class="relative z-10">
            <h3 class="text-3xl font-black text-[#21275a] mb-4 tracking-tight">Industry-First Learning</h3>
            <p class="text-[#21275a]/40 font-bold text-xs uppercase tracking-widest mb-12">Skills That Get You Hired</p>
            <ul class="space-y-6">
              {[
                "Sessions by Industry Engineers — Learn from professionals at top tech companies",
                "Coding from Day 1 — Real projects, hackathons, and hands-on labs from week one",
                "AI-First Curriculum — Every program integrates AI tools and workflows",
                "CXO Masterclasses — Executive-led sessions on leadership and entrepreneurship",
                "No JEE Required — Admission via ISAT — merit through aptitude and passion"
              ].map(text => (
                <li class="flex items-center gap-4 group/item">
                  <div class="w-10 h-10 rounded-full bg-[#b00f1e]/10 flex items-center justify-center flex-shrink-0 group-hover/item:bg-[#b00f1e]/20 transition-colors">
                    <svg class="w-5 h-5 text-[#b00f1e]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                  </div>
                  <span class="font-bold text-xs uppercase tracking-widest text-[#21275a] leading-relaxed">{text}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- USPs SECTION -->
  <section class="bg-gray-50 py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-24 reveal">
        <div class="inline-block bg-[#b00f1e]/5 text-[#b00f1e] text-[10px] font-black uppercase tracking-[0.4em] px-8 py-3 rounded-full mb-6">
          Why IIAT?
        </div>
        <h2 class="text-5xl md:text-7xl font-black text-[#21275a] mb-6 tracking-tighter">
          The IIAT Edge
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 reveal">
        {[
          {
            title: "World-Class Degree, Zero Compromise",
            desc: "UGC-MHRD recognized B.Tech degree + IIAT industry certification — valid for government jobs, MS abroad, PSUs, and corporate hiring."
          },
          {
            title: "Industry-Integrated Curriculum",
            desc: "Designed with IIT alumni and engineers from top global companies. CS fundamentals at core — DSA, OS, Networks — with AI/ML and emerging tech specializations."
          },
          {
            title: "A Portfolio That Speaks Before You Do",
            desc: "5,000+ hours of hands-on coding, 50+ production-grade projects. Students graduate with a verified portfolio, live open-source contributions, and NPTEL Certifications from IITs."
          },
          {
            title: "Trained to Compete on the World Stage",
            desc: "ACM ICPC, LeetCode, Codeforces preparation tracks. Google Summer of Code mentorship. Students build a global reputation through real stipends and worldwide contest rankings."
          },
          {
            title: "Industry-Ready from Year 2",
            desc: "Structured internships from second year. Real work experience, industry mentors, and Pre-Placement Offers before graduation. Global exposure programs and CXO interactions."
          },
          {
            title: "Elite Mentorship, Accessible to Every Corner of India",
            desc: "IIT-calibre mentorship from IIT alumni, startup founders, and senior industry leaders. Merit-based scholarships. In-house startup incubator, seed funding, and creator-preneur track."
          }
        ].map((usp, i) => (
          <div class="bg-white p-10 rounded-[40px] border border-[#21275a]/5 hover:border-[#b00f1e]/20 hover:shadow-[0_40px_100px_rgba(176,15,30,0.05)] transition-all duration-500 group">
            <div class="w-14 h-14 rounded-2xl bg-[#21275a] text-[#f7ba26] flex items-center justify-center font-black text-xl mb-8 group-hover:bg-[#b00f1e] group-hover:text-white transition-colors duration-500">
              0{i+1}
            </div>
            <h3 class="text-xl font-black text-[#21275a] mb-4 leading-tight group-hover:text-[#b00f1e] transition-colors">{usp.title}</h3>
            <p class="text-[#21275a]/50 text-sm leading-relaxed">{usp.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COURSE DETAILS / APPLICATION -->
  <section class="bg-white py-32 px-6 relative overflow-hidden">
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-[#f7ba26]/5 blur-[120px] rounded-full -translate-x-1/2 translate-y-1/2"></div>
    <div class="max-w-6xl mx-auto relative z-10">
      <div class="grid lg:grid-cols-2 gap-20 items-center reveal">
        <div>
          <div class="inline-block bg-[#b00f1e]/5 text-[#b00f1e] text-[10px] font-black uppercase tracking-[0.4em] px-8 py-3 rounded-full mb-8">
            Admissions 2026
          </div>
          <h2 class="text-5xl md:text-7xl font-black text-[#21275a] mb-8 tracking-tighter leading-none">
            Your Journey <br/> <span class="text-[#b00f1e]">Starts Here</span>
          </h2>
          <div class="space-y-6 mb-12">
            {[
              { label: "Duration", val: "4 Years (8 Semesters)" },
              { label: "Eligibility", val: "10+2 / Intermediate with PCB or PCM — Minimum passing marks" },
              { label: "Selection", val: "ISAT — Free to register" },
              { label: "Fee", val: "₹1,50,000 – ₹2,00,000 per year" },
              { label: "University", val: "St. Mary's Rehabilitation University, Hyderabad" }
            ].map(item => (
              <div class="flex flex-col gap-1">
                <span class="text-[10px] font-black uppercase tracking-[0.3em] text-[#21275a]/30">{item.label}</span>
                <span class="text-lg font-bold text-[#21275a]">{item.val}</span>
              </div>
            ))}
          </div>
          <div class="flex flex-wrap gap-4">
            <a href="/register" class="bg-[#b00f1e] text-white font-black uppercase tracking-widest text-xs px-10 py-5 rounded-full hover:scale-110 transition-transform shadow-2xl shadow-[#b00f1e]/20">
              Register for ISAT — Free
            </a>
            <a href="tel:+918688664337" class="bg-[#21275a] text-white font-black uppercase tracking-widest text-xs px-10 py-5 rounded-full hover:scale-110 transition-transform">
              Call Admissions
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 bg-gradient-to-tr from-[#21275a] to-[#21275a]/80 rounded-[64px] -rotate-3 group-hover:rotate-0 transition-transform duration-700"></div>
          <div class="relative bg-[#21275a] border border-white/10 rounded-[64px] p-12 md:p-16 text-white overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-[#f7ba26]/20 blur-[80px] rounded-full translate-x-1/2 -translate-y-1/2"></div>
            <h3 class="text-3xl font-black mb-10 tracking-tight leading-tight">
              IIAT Scholarship <br/> <span class="text-[#f7ba26]">Assessment Test</span>
            </h3>
            <div class="space-y-8 mb-12">
              <div class="flex gap-6 group/step">
                <div class="w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 group-hover/step:bg-[#f7ba26]/20 group-hover/step:border-[#f7ba26]/30 transition-all font-black text-[#f7ba26]">01</div>
                <div>
                  <h4 class="font-black text-sm uppercase tracking-widest mb-2">Register</h4>
                  <p class="text-white/40 text-xs leading-relaxed font-medium">Free registration at iiath.com. Select your slot for ISAT 2026.</p>
                </div>
              </div>
              <div class="flex gap-6 group/step">
                <div class="w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 group-hover/step:bg-[#f7ba26]/20 group-hover/step:border-[#f7ba26]/30 transition-all font-black text-[#f7ba26]">02</div>
                <div>
                  <h4 class="font-black text-sm uppercase tracking-widest mb-2">Assess</h4>
                  <p class="text-white/40 text-xs leading-relaxed font-medium">Gamified testing on reasoning, observations, PCM, and logical ability.</p>
                </div>
              </div>
              <div class="flex gap-6 group/step">
                <div class="w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 group-hover/step:bg-[#f7ba26]/20 group-hover/step:border-[#f7ba26]/30 transition-all font-black text-[#f7ba26]">03</div>
                <div>
                  <h4 class="font-black text-sm uppercase tracking-widest mb-2">Unlock</h4>
                  <p class="text-white/40 text-xs leading-relaxed font-medium">Secure your seat and merit-based scholarship slabs up to 100%.</p>
                </div>
              </div>
            </div>
            <p class="text-[10px] font-black uppercase tracking-[0.4em] text-white/20 text-center">No JEE Required &bull; Merit Based Admission</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="bg-[#21275a] py-32 px-6 relative overflow-hidden">
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
    <div class="max-w-4xl mx-auto text-center reveal">
      <h2 class="text-5xl md:text-7xl font-black text-white mb-10 tracking-tighter leading-none italic">
        Ready to Build <br/> <span class="text-[#f7ba26]">The Future?</span>
      </h2>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="/register" class="bg-[#b00f1e] text-white font-black uppercase tracking-widest text-xs px-12 py-5 rounded-full hover:bg-white hover:text-[#21275a] transition-all transform hover:scale-110">
          Start Your ISAT Now
        </a>
      </div>
    </div>
  </section>

  <!-- HIRING PARTNER MARQUEE -->
  <section class="bg-gray-50 py-24 px-6 overflow-hidden border-y border-gray-100">
    <div class="max-w-7xl mx-auto text-center mb-16 reveal">
      <h2 class="text-4xl font-black text-[#21275a] mb-4 tracking-tight">Hiring Partners</h2>
      <p class="text-[#21275a]/40 font-black text-xs uppercase tracking-[0.4em]">Where our graduates launch their careers</p>
    </div>
    <div class="relative flex overflow-hidden">
      <div class="flex gap-12 animate-ticker whitespace-nowrap">
        {[
          "google", "microsoft", "amazon", "meta", "netflix", "infosys", "tata-consultancy-services", 
          "wipro", "hcl", "accenture", "ibm", "oracle", "deloitte", "kpmg", "goldmansachs",
          "google", "microsoft", "amazon", "meta", "netflix", "infosys", "tata-consultancy-services", 
          "wipro", "hcl", "accenture", "ibm", "oracle", "deloitte", "kpmg", "goldmansachs"
        ].map(co => (
          <div class="shrink-0 flex items-center justify-center grayscale hover:grayscale-0 transition-all duration-300">
            <img src={`https://cdn.simpleicons.org/${co}`} alt={co} class="h-8 w-auto opacity-30 hover:opacity-100 transition-opacity" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROGRAMS GRID -->
  <section id="programs" class="bg-white py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 reveal">
        <div class="inline-block bg-[#f7ba26]/20 text-[#21275a] text-xs font-extrabold uppercase tracking-widest px-5 py-2 rounded-full mb-4">B.Tech Specializations</div>
        <h2 class="text-4xl md:text-5xl font-black text-[#21275a] mb-4 tracking-tight">Choose Your Future</h2>
        <div class="w-16 h-1 bg-[#f7ba26] mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 reveal">
        {[
          {
            title: "B.Tech CSE",
            spec: "AI & Data Science",
            seats: "180",
            careers: "Data Scientist / ML Engineer / AI Research Analyst / NLP Engineer / Computer Vision Engineer / AI Product Manager",
            slug: "btech-ai-ds"
          },
          {
            title: "B.Tech CSE",
            spec: "FinTech & Artificial Intelligence",
            seats: "60",
            careers: "FinTech Product Manager / Blockchain Developer / Quantitative Analyst / Algorithmic Trader / Risk Analyst / Payment Systems Engineer",
            slug: "btech-fintech"
          },
          {
            title: "B.Tech CSE",
            spec: "Core",
            seats: "180",
            careers: "Software Engineer / Full Stack Developer / Cloud & DevOps Engineer / Backend Engineer / Site Reliability Engineer / Solutions Architect",
            slug: "btech-core"
          },
          {
            title: "B.Tech CSE",
            spec: "AI & Machine Learning",
            seats: "180",
            careers: "Deep Learning Scientist / Generative AI Developer / MLOps Engineer / AI Research Engineer / LLM Engineer / AI Infrastructure Engineer",
            slug: "btech-ai-ml"
          },
          {
            title: "B.Tech CSE",
            spec: "Cyber Security with AI/ML",
            seats: "60",
            careers: "Cybersecurity Analyst / Ethical Hacker / SOC Analyst / Penetration Tester / Threat Intelligence Analyst / Cloud Security Engineer",
            slug: "btech-cyber"
          },
          {
            title: "B.Tech Biomedical Engineering, AI and Medical Robotics",
            spec: "",
            seats: "60",
            careers: "Biomedical Equipment Technician / Clinical Engineer / HealthTech AI Specialist / Medical Imaging Analyst / MedTech Product Designer",
            slug: "btech-biomedical"
          }
        ].map(p => (
          <a href={`/programs/${p.slug}`}
            class="group border-2 border-[#21275a]/5 rounded-3xl p-8 flex flex-col bg-white hover:border-[#b00f1e] hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2">
            <div class="flex items-start justify-between mb-8">
              <div class="inline-block px-4 py-1.5 bg-[#f7ba26]/10 text-[#21275a] font-extrabold rounded-lg text-xs uppercase tracking-widest">
                Seats: {p.seats}
              </div>
            </div>
            <h3 class="text-2xl font-black text-[#21275a] leading-tight mb-2">{p.title}</h3>
            {p.spec && <p class="text-[#b00f1e] font-bold text-sm mb-6 flex-1 italic">({p.spec})</p>}
            <div class="mt-4 pt-4 border-t border-[#21275a]/5">
              <p class="text-[10px] text-[#21275a]/30 font-black uppercase tracking-widest mb-3">Career Paths</p>
              <p class="text-xs text-[#21275a]/60 leading-relaxed line-clamp-2">{p.careers}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROGRAMS GRID -->
  <section id="programs" class="bg-white py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 reveal">
        <div class="inline-block bg-[#f7ba26]/20 text-[#21275a] text-xs font-extrabold uppercase tracking-widest px-5 py-2 rounded-full mb-4">B.Tech Programs</div>
        <h2 class="text-4xl md:text-5xl font-black text-[#21275a] mb-4">Your Degree, Your Specialization</h2>
        <div class="w-16 h-1 bg-[#f7ba26] mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal">
        {[
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
            num: "01",
            title: "B.Tech CSE",
            spec: "AI & Data Science",
            seats: "180 Seats",
            slug: "btech-ai-ds"
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1"/>`,
            num: "02",
            title: "B.Tech CSE",
            spec: "FinTech & Artificial Intelligence",
            seats: "60 Seats",
            slug: "btech-fintech"
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>`,
            num: "03",
            title: "B.Tech CSE",
            spec: "Core",
            seats: "180 Seats",
            slug: "btech-core"
          },
          {
