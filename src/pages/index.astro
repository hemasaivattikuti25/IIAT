---
import Layout from '../layouts/Layout.astro';
---

<Layout title="IIAT Hyderabad | Where Curiosity Becomes Capability">

  <!-- HERO: Full-screen video background -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <!-- Video Background -->
    <video
      class="absolute inset-0 w-full h-full object-cover"
      autoplay muted loop playsinline
      poster="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=1920&q=80"
    >
      <source src="https://assets.mixkit.co/videos/preview/mixkit-digital-animation-of-a-circuit-board-2436-large.mp4" type="video/mp4" />
    </video>

    <!-- Dark overlay with navy tint -->
    <div class="absolute inset-0 bg-[#21275a]/85"></div>

    <!-- Grid pattern overlay -->
    <div class="absolute inset-0" style="background-image: linear-gradient(rgba(225,29,72,.1) 1px, transparent 1px), linear-gradient(90deg, rgba(225,29,72,.1) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <!-- Hero Content -->
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 bg-[#e11d48]/10 border border-[#e11d48]/30 text-white text-[10px] font-black uppercase tracking-[0.3em] px-8 py-3 rounded-full mb-10 backdrop-blur-md">
        <span class="w-2 h-2 bg-[#e11d48] rounded-full animate-pulse"></span>
        India's Most Advanced AI-First B.Tech Program
      </div>

      <h1 class="text-6xl md:text-8xl lg:text-9xl font-black text-white leading-none tracking-tighter mb-8 italic">
        IIAT<br/>
        <span class="text-[#f7ba26]">PHASE</span>
        <span class="text-white"> 02</span>
      </h1>

      <p class="text-xl md:text-2xl text-white/70 font-medium max-w-3xl mx-auto mb-12 leading-relaxed">
        IIAT - Indian Institute of Advanced Technologies. <br/>
        Where world-class infrastructure meets Silicon Valley engineering.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="/register"
          class="inline-flex items-center gap-4 bg-[#e11d48] text-white font-black uppercase tracking-widest text-sm px-12 py-5 rounded-full hover:bg-white hover:text-[#21275a] transition-all transform hover:scale-110 shadow-2xl shadow-[#e11d48]/20">
          Start Your Journey
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/contact"
          class="inline-flex items-center gap-4 bg-white/5 backdrop-blur-xl border border-white/20 text-white font-black uppercase tracking-widest text-sm px-12 py-5 rounded-full hover:bg-white/10 transition-all">
          Download Guide
        </a>
      </div>

      <!-- Designed by badge -->
      <div class="mt-20">
        <p class="text-white/30 text-[10px] font-black uppercase tracking-[0.4em] mb-6">Built by engineers from</p>
        <div class="flex flex-wrap items-center justify-center gap-10 opacity-50 grayscale hover:grayscale-0 transition-all">
          <span class="text-white font-black text-xs uppercase tracking-widest">Google</span>
          <span class="text-white font-black text-xs uppercase tracking-widest">Microsoft</span>
          <span class="text-white font-black text-xs uppercase tracking-widest">Amazon</span>
          <span class="text-white font-black text-xs uppercase tracking-widest">Meta</span>
          <span class="text-white font-black text-xs uppercase tracking-widest">Netflix</span>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 group">
      <span class="text-[10px] font-black uppercase tracking-[0.5em] text-white/20 group-hover:text-[#e11d48] transition-colors">Scroll</span>
      <div class="w-0.5 h-12 bg-gradient-to-b from-[#e11d48] to-transparent"></div>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="bg-[#21275a] py-20 px-6 border-y border-white/5">
    <div class="max-w-7xl mx-auto grid grid-cols-2 lg:grid-cols-4 gap-12 reveal">
      {[
        { num: "500+", label: "Elite Students" },
        { num: "06", label: "AI Specializations" },
        { num: "100%", label: "Placement Goal" },
        { num: "IIT", label: "Alumni Faculty" },
      ].map(s => (
        <div class="text-center group">
          <div class="text-5xl lg:text-7xl font-black text-white mb-4 group-hover:text-[#f7ba26] transition-colors tabular-nums tracking-tighter">{s.num}</div>
          <div class="text-white/30 font-black text-[10px] uppercase tracking-[0.3em]">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- BEST OF BOTH WORLDS -->
  <section class="bg-white py-32 px-6 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-[#e11d48]/5 blur-[120px] rounded-full translate-x-1/2 -translate-y-1/2"></div>
    <div class="max-w-6xl mx-auto relative z-10">
      <div class="text-center mb-24 reveal">
        <div class="inline-block bg-[#e11d48]/5 text-[#e11d48] text-[10px] font-black uppercase tracking-[0.4em] px-8 py-3 rounded-full mb-6">
          The IIAT Advantage
        </div>
        <h2 class="text-5xl md:text-7xl font-black text-[#21275a] mb-6 tracking-tighter">
          Best of Both Worlds
        </h2>
        <p class="text-[#21275a]/50 text-xl font-medium max-w-2xl mx-auto leading-relaxed">
          IIAT - Indian Institute of Advanced Technologies combines academic rigor with industry speed.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 reveal">
        <!-- University Excellence -->
        <div class="bg-[#21275a] rounded-[48px] p-16 text-white relative overflow-hidden group">
          <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <div class="relative z-10">
            <div class="w-16 h-16 rounded-[24px] bg-white/10 flex items-center justify-center mb-10 group-hover:scale-110 transition-transform">
               <svg class="w-8 h-8 text-[#f7ba26]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <h3 class="text-3xl font-black mb-4 tracking-tight text-[#f7ba26]">University Excellence</h3>
            <p class="text-white/40 font-bold text-xs uppercase tracking-widest mb-12">Academic Rigor & Credential</p>
            <ul class="space-y-6">
              {[
                { text: "UGC Approved B.Tech Degree", icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" },
                { text: "State-of-the-Art Campus", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
                { text: "Vibrant Campus Life", icon: "M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
                { text: "Interdisciplinary Curriculum", icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" },
                { text: "Fully Residential Campus", icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" }
              ].map(item => (
                <li class="flex items-center gap-4 group/item">
                  <div class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center flex-shrink-0 group-hover/item:bg-[#f7ba26]/20 transition-colors">
                    <svg class="w-5 h-5 text-white/40 group-hover/item:text-[#f7ba26]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/></svg>
                  </div>
                  <span class="font-black text-xs uppercase tracking-widest">{item.text}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Industry-First Learning -->
        <div class="bg-white border border-[#21275a]/5 rounded-[48px] p-16 relative overflow-hidden group shadow-[0_40px_100px_rgba(0,0,0,0.02)]">
          <div class="absolute inset-x-0 bottom-0 h-2 bg-[#e11d48] scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-700"></div>
          <div class="relative z-10">
            <div class="w-16 h-16 rounded-[24px] bg-[#e11d48]/5 flex items-center justify-center mb-10 group-hover:scale-110 transition-transform">
              <svg class="w-8 h-8 text-[#e11d48]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            </div>
            <h3 class="text-3xl font-black text-[#21275a] mb-4 tracking-tight">Industry-First Learning</h3>
            <p class="text-[#21275a]/40 font-bold text-xs uppercase tracking-widest mb-12">Skills That Get You Hired</p>
            <ul class="space-y-6">
              {[
                { text: "Sessions by Industry Engineers", icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" },
                { text: "Coding from Day 1", icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" },
                { text: "AI-First Curriculum", icon: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" },
                { text: "CXO Masterclasses", icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" },
                { text: "Admission via ISAT", icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" }
              ].map(item => (
                <li class="flex items-center gap-4 group/item">
                  <div class="w-10 h-10 rounded-full bg-[#21275a]/5 flex items-center justify-center flex-shrink-0 group-hover/item:bg-[#e11d48]/10 transition-colors">
                    <svg class="w-5 h-5 text-[#21275a]/20 group-hover/item:text-[#e11d48]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/></svg>
                  </div>
                  <span class="font-black text-xs uppercase tracking-widest text-[#21275a]">{item.text}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ECOSYSTEM / PARTNER STRIP -->
  <section class="bg-gray-50 py-24 px-6 overflow-hidden border-y border-gray-100">
    <div class="max-w-7xl mx-auto text-center mb-16 reveal">
      <h2 class="text-4xl font-black text-[#21275a] mb-4 tracking-tight">Our Ecosystem</h2>
      <p class="text-[#21275a]/40 font-black text-xs uppercase tracking-[0.4em]">Where our mentors and alumni lead</p>
    </div>
    <div class="relative flex overflow-hidden">
      <div class="flex gap-4 animate-ticker whitespace-nowrap">
        {[
          "Google", "Microsoft", "Amazon", "Meta", "Netflix", "Infosys", "TCS", "Wipro", "HCL", "Accenture", "IBM", "Oracle", "Deloitte", "KPMG", "Goldman Sachs",
          "Google", "Microsoft", "Amazon", "Meta", "Netflix", "Infosys", "TCS", "Wipro", "HCL", "Accenture", "IBM", "Oracle", "Deloitte", "KPMG", "Goldman Sachs"
        ].map(co => (
          <div class="inline-flex items-center justify-center bg-white border border-gray-100 rounded-[24px] px-12 py-6 shrink-0 shadow-sm hover:shadow-xl hover:border-[#e11d48]/10 transition-all group">
            <span class="font-black text-[#21275a]/30 group-hover:text-[#21275a] text-sm uppercase tracking-widest transition-colors">{co}</span>
          </div>
        ))}
      </div>
    </div>
  </section>ion>

  <!-- PROGRAMS GRID -->
  <section id="programs" class="bg-white py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 reveal">
        <div class="inline-block bg-[#f7ba26]/20 text-[#21275a] text-xs font-extrabold uppercase tracking-widest px-5 py-2 rounded-full mb-4">B.Tech Programs</div>
        <h2 class="text-4xl md:text-5xl font-black text-[#21275a] mb-4">Your Degree, Your Specialization</h2>
        <div class="w-16 h-1 bg-[#f7ba26] mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal">
        {[
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>`,
            num: "01",
            title: "B.Tech CSE",
            spec: "AI & Data Science",
            seats: "180 Seats",
            slug: "btech-ai-ds"
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1"/>`,
            num: "02",
            title: "B.Tech CSE",
            spec: "FinTech & Artificial Intelligence",
            seats: "60 Seats",
            slug: "btech-fintech"
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>`,
            num: "03",
            title: "B.Tech CSE",
            spec: "Core",
            seats: "180 Seats",
            slug: "btech-core"
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>`,
            num: "04",
            title: "B.Tech CSE",
            spec: "AI & Machine Learning",
            seats: "180 Seats",
            slug: "btech-ai-ml"
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
            num: "05",
            title: "B.Tech CSE",
            spec: "Cyber Security with AI/ML",
            seats: "60 Seats",
            slug: "btech-cyber"
          },
          {
            icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>`,
            num: "06",
            title: "B.Tech",
            spec: "Biomedical Engineering, AI & Medical Robotics",
            seats: "60 Seats",
            slug: "btech-biomedical"
          }
        ].map(p => (
          <a href={`/programs/${p.slug}`}
            class="group border-2 border-[#21275a]/10 rounded-2xl p-8 flex flex-col bg-white hover:border-[#b00f1e] hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
            <div class="flex items-start justify-between mb-6">
              <div class="w-12 h-12 rounded-xl bg-[#b00f1e]/10 flex items-center justify-center group-hover:bg-[#b00f1e] transition-colors">
                <svg class="w-6 h-6 text-[#b00f1e] group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={p.icon} />
                </svg>
              </div>
              <span class="text-4xl font-black text-[#21275a]/10 group-hover:text-[#b00f1e]/20 transition-colors">{p.num}</span>
            </div>
            <h3 class="text-lg font-black text-[#21275a] mb-1">{p.title}</h3>
            <p class="text-[#b00f1e] font-bold text-base mb-6 flex-1">({p.spec})</p>
            <div class="flex items-center justify-between">
              <span class="inline-block px-4 py-1.5 bg-[#f7ba26]/20 text-[#21275a] font-extrabold rounded-lg text-sm">{p.seats}</span>
              <svg class="w-5 h-5 text-[#21275a]/30 group-hover:text-[#b00f1e] group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CAMPUS SECTION -->
  <section class="bg-[#21275a]/5 py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 reveal">
        <div class="inline-block bg-[#f7ba26]/20 text-[#21275a] text-xs font-extrabold uppercase tracking-widest px-5 py-2 rounded-full mb-4">Our Campuses</div>
        <h2 class="text-4xl md:text-5xl font-black text-[#21275a] mb-4">Experience Life at Campus</h2>
        <p class="text-[#21275a]/60 max-w-2xl mx-auto">IIAT collaborates with cutting-edge university campuses across India, giving students world-class learning spaces right where innovation thrives.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 reveal">
        {[
          { name: "Sri Siddhartha Academy of Higher Education", abbr: "SSAHE", location: "Tumkur, Karnataka", programs: "AI & Data Science, FinTech, Cyber Security", img: "https://images.unsplash.com/photo-1562774053-701939374585?w=800&q=80" },
          { name: "Malla Reddy Deemed to be University", abbr: "MRDU", location: "Hyderabad, Telangana", programs: "Core CSE, AI & ML, Biomedical Engineering", img: "https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=800&q=80" }
        ].map(c => (
          <div class="group relative rounded-3xl overflow-hidden h-72 cursor-pointer">
            <img src={c.img} alt={c.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            <div class="absolute inset-0 bg-gradient-to-t from-[#21275a]/95 via-[#21275a]/40 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-8">
              <div class="inline-block bg-[#f7ba26] text-[#21275a] text-xs font-black uppercase tracking-widest px-3 py-1 rounded-lg mb-3">{c.abbr}</div>
              <h3 class="text-white font-black text-xl mb-1">{c.name}</h3>
              <p class="text-white/60 text-sm mb-2">{c.location}</p>
              <p class="text-white/50 text-xs">{c.programs}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="bg-white py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 reveal">
        <div class="inline-block bg-[#f7ba26]/20 text-[#21275a] text-xs font-extrabold uppercase tracking-widest px-5 py-2 rounded-full mb-4">Student Stories</div>
        <h2 class="text-4xl md:text-5xl font-black text-[#21275a]">Hear From Our Students</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6 reveal">
        {[
          { name: "Arjun Sharma", course: "B.Tech AI & Data Science, 2025", quote: "IIAT's AI-first curriculum gave me industry exposure from day 1. I landed my dream internship at a MAANG company in 3rd year." },
          { name: "Priya Reddy", course: "B.Tech Cyber Security, 2025", quote: "The CXO masterclasses and hands-on projects are unmatched. The professors have real industry experience, not just theory." },
          { name: "Rahul Kumar", course: "B.Tech CSE Core, 2024", quote: "No JEE pressure, still a UGC recognized B.Tech degree. ISAT made it accessible and the quality of education is exceptional." }
        ].map(t => (
          <div class="bg-[#21275a]/5 rounded-2xl p-8 hover:bg-white hover:shadow-xl hover:border border-[#21275a]/10 transition-all">
            <div class="flex mb-4">
              {[1,2,3,4,5].map(_ => (
                <svg class="w-4 h-4 text-[#f7ba26]" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-[#21275a]/70 text-sm leading-relaxed mb-6 italic">"{t.quote}"</p>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-[#b00f1e] flex items-center justify-center text-white font-black text-sm">{t.name[0]}</div>
              <div>
                <div class="font-bold text-[#21275a] text-sm">{t.name}</div>
                <div class="text-[#21275a]/50 text-xs">{t.course}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ ACCORDION -->
  <section class="bg-[#21275a]/5 py-28 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16 reveal">
        <div class="inline-block bg-[#f7ba26]/20 text-[#21275a] text-xs font-extrabold uppercase tracking-widest px-5 py-2 rounded-full mb-4">FAQs</div>
        <h2 class="text-4xl md:text-5xl font-black text-[#21275a]">Frequently Asked Questions</h2>
      </div>

      <div class="space-y-4 reveal" id="faq-container">
        {[
          { q: "What is ISAT?", a: "ISAT (IIAT Scholarship Assessment Test) is IIAT's entrance exam. It is free to register and does not require JEE scores. It tests logical reasoning, aptitude, and basic math." },
          { q: "Is JEE mandatory to join IIAT?", a: "No. JEE is NOT required for IIAT. Admission is based on ISAT performance. This makes quality technical education accessible to all deserving students." },
          { q: "Are the B.Tech degrees UGC recognized?", a: "Yes. All B.Tech programs at IIAT are offered in partnership with UGC-recognized universities (SSAHE and MRDU). The degree is valid for all government and private sector jobs." },
          { q: "What is the fee structure?", a: "Fee details vary by campus and program. Contact us at info@iiath.com or call +91 8688664337 for the complete fee structure and scholarship information." },
          { q: "What specializations are available?", a: "IIAT offers 6 B.Tech specializations: AI & Data Science, FinTech & AI, Cyber Security with AI/ML, Core CSE, AI & Machine Learning, and Biomedical Engineering with AI & Medical Robotics." },
          { q: "Is campus residential?", a: "Yes, both our campuses offer fully residential facilities with modern hostels, sports infrastructure, and 24x7 security." }
        ].map((f, i) => (
          <div class="bg-white rounded-2xl border border-[#21275a]/10 overflow-hidden faq-item">
            <button
              class="w-full flex justify-between items-center px-8 py-6 text-left font-bold text-[#21275a] hover:text-[#b00f1e] transition-colors faq-trigger"
              data-index={i}
            >
              {f.q}
              <svg class="w-5 h-5 flex-shrink-0 ml-4 transition-transform faq-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300">
              <p class="px-8 pb-6 text-[#21275a]/70 leading-relaxed">{f.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="bg-[#b00f1e] py-20 px-6">
    <div class="max-w-4xl mx-auto text-center reveal">
      <h2 class="text-4xl md:text-6xl font-black text-white mb-6">Ready to Begin?</h2>
      <p class="text-white/80 text-xl mb-10">Join IIAT Hyderabad — No JEE Required. Register for a free ISAT and secure your seat in India's most industry-integrated B.Tech program.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/register" class="bg-white text-[#b00f1e] font-extrabold text-lg px-12 py-5 rounded-xl hover:bg-[#f7ba26] transition-all transform hover:scale-105">
          Register for ISAT — Free
        </a>
        <a href="tel:+918688664337" class="border-2 border-white text-white font-bold text-lg px-12 py-5 rounded-xl hover:bg-white/10 transition-all">
          Call: +91 8688664337
        </a>
      </div>
    </div>
  </section>

</Layout>

<script>
  // FAQ Accordion
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const answer = item?.querySelector('.faq-answer') as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as HTMLElement;
      const isOpen = answer?.style.maxHeight && answer.style.maxHeight !== '0px';

      // Close all
      document.querySelectorAll('.faq-answer').forEach((el: Element) => {
        (el as HTMLElement).style.maxHeight = '0px';
      });
      document.querySelectorAll('.faq-icon').forEach((el: Element) => {
        el.classList.remove('rotate-180');
      });

      // Open clicked if was closed
      if (!isOpen && answer) {
        answer.style.maxHeight = answer.scrollHeight + 'px';
        icon?.classList.add('rotate-180');
      }
    });
  });
</script>
