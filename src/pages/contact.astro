---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | IIAT Hyderabad">
  <section class="bg-white py-28 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <div class="inline-block bg-[#f7ba26]/20 text-[#21275a] text-xs font-extrabold uppercase tracking-widest px-5 py-2 rounded-full mb-4">Get in Touch</div>
        <h1 class="text-5xl md:text-6xl font-black text-[#21275a] mb-6">Contact Us</h1>
        <p class="text-xl text-[#21275a]/70">Our admission counsellors are happy to help. Reach out today.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div class="bg-[#21275a]/5 rounded-3xl p-10">
          <h2 class="text-2xl font-black text-[#21275a] mb-8">Send us a message</h2>
          <form class="space-y-5">
            <div>
              <label class="block text-sm font-bold text-[#21275a] mb-2">Full Name</label>
              <input type="text" placeholder="Your full name" class="w-full border-2 border-[#21275a]/10 rounded-xl px-5 py-3 text-[#21275a] focus:outline-none focus:border-[#b00f1e] transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-bold text-[#21275a] mb-2">Email</label>
              <input type="email" placeholder="your@email.com" class="w-full border-2 border-[#21275a]/10 rounded-xl px-5 py-3 text-[#21275a] focus:outline-none focus:border-[#b00f1e] transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-bold text-[#21275a] mb-2">Phone</label>
              <input type="tel" placeholder="+91 XXXXX XXXXX" class="w-full border-2 border-[#21275a]/10 rounded-xl px-5 py-3 text-[#21275a] focus:outline-none focus:border-[#b00f1e] transition-colors" />
            </div>
            <div>
              <label class="block text-sm font-bold text-[#21275a] mb-2">Program of Interest</label>
              <select class="w-full border-2 border-[#21275a]/10 rounded-xl px-5 py-3 text-[#21275a] focus:outline-none focus:border-[#b00f1e] transition-colors bg-white">
                <option>B.Tech CSE (AI & Data Science)</option>
                <option>B.Tech CSE (FinTech & AI)</option>
                <option>B.Tech CSE (Cyber Security)</option>
                <option>B.Tech CSE (Core)</option>
                <option>B.Tech CSE (AI & ML)</option>
                <option>B.Tech Biomedical Engineering</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-bold text-[#21275a] mb-2">Message</label>
              <textarea rows="4" placeholder="Any questions?" class="w-full border-2 border-[#21275a]/10 rounded-xl px-5 py-3 text-[#21275a] focus:outline-none focus:border-[#b00f1e] transition-colors resize-none"></textarea>
            </div>
            <button class="w-full bg-[#b00f1e] text-white font-extrabold py-4 rounded-xl hover:bg-[#8a0c17] transition-colors">Send Message</button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="space-y-8">
          <div class="bg-[#21275a] rounded-3xl p-8 text-white">
            <h3 class="font-black text-xl mb-6 text-[#f7ba26]">Admissions Office</h3>
            <div class="space-y-5">
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-[#f7ba26]/20 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-[#f7ba26]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498A1 1 0 0121 15.72V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <div class="font-bold text-sm">Phone</div>
                  <a href="tel:+918688664337" class="text-white/70 hover:text-[#f7ba26] transition-colors">+91 8688664337</a>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-[#f7ba26]/20 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-[#f7ba26]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <div class="font-bold text-sm">Email</div>
                  <a href="mailto:info@iiath.com" class="text-white/70 hover:text-[#f7ba26] transition-colors">info@iiath.com</a>
                </div>
              </div>
              <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-xl bg-[#f7ba26]/20 flex items-center justify-center flex-shrink-0">
                  <svg class="w-5 h-5 text-[#f7ba26]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                </div>
                <div>
                  <div class="font-bold text-sm">Website</div>
                  <a href="https://iiath.com" class="text-white/70 hover:text-[#f7ba26] transition-colors">iiath.com</a>
                </div>
              </div>
            </div>
          </div>

          <div class="border-2 border-[#21275a]/10 rounded-3xl p-8">
            <h3 class="font-black text-xl text-[#21275a] mb-4">Office Hours</h3>
            <div class="space-y-2 text-sm text-[#21275a]/70">
              <div class="flex justify-between"><span>Monday – Saturday</span><span class="font-bold text-[#21275a]">9:00 AM – 6:00 PM</span></div>
              <div class="flex justify-between"><span>Sunday</span><span class="font-bold text-[#b00f1e]">Closed</span></div>
            </div>
          </div>

          <a href="/register" class="block bg-[#b00f1e] text-white text-center font-extrabold text-lg py-5 rounded-2xl hover:bg-[#8a0c17] transition-all transform hover:scale-105">
            Register for ISAT — Free
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
