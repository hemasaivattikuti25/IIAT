---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AI Playground | IIAT Hyderabad">
  <div class="relative bg-white overflow-hidden selection:bg-[#e11d48]/20">
    
    <!-- Background Elements -->
    <div class="fixed inset-0 pointer-events-none z-0">
      <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(#e11d48 0.5px, transparent 0.5px); background-size: 30px 30px;"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] border border-[#e11d48]/5 rounded-full animate-[spin_60s_linear_infinite]"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1200px] h-[1200px] border border-[#e11d48]/5 rounded-full animate-[spin_90s_linear_infinite_reverse]"></div>
    </div>

    <!-- Floating Navigation Dock -->
    <div class="fixed bottom-10 left-1/2 -translate-x-1/2 z-50 flex items-center bg-white/90 backdrop-blur-xl px-2 py-2 rounded-full shadow-2xl border border-[#e11d48]/10 group transition-all hover:scale-105 active:scale-95">
      <a href="#hero" class="p-4 rounded-full hover:bg-[#e11d48]/5 text-[#21275a] hover:text-[#e11d48] transition-all" aria-label="Home">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      </a>
      <div class="w-px h-6 bg-gray-100 mx-2"></div>
      {[
        { id: "resume", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>` },
        { id: "predict", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>` },
        { id: "practice", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>` },
        { id: "interview", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>` }
      ].map(item => (
        <a href={`#${item.id}`} class="p-4 rounded-full hover:bg-[#e11d48]/5 text-[#21275a] hover:text-[#e11d48] transition-all" aria-label={item.id}>
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><Fragment set:html={item.icon} /></svg>
        </a>
      ))}
    </div>

    <!-- Main Content -->
    <div class="relative z-10">
      
      <!-- Hero Section -->
      <section id="hero" class="min-h-screen flex flex-col items-center justify-center text-center px-6">
        <div class="max-w-4xl">
          <div class="inline-block bg-[#e11d48]/10 text-[#e11d48] text-xs font-black uppercase tracking-[0.3em] px-6 py-2 rounded-full mb-8">
            The Agentic Multiverse
          </div>
          <h1 class="text-7xl md:text-9xl font-black text-[#21275a] mb-8 leading-tight tracking-tighter">
            Build the <span class="text-[#e11d48]">Future</span> <br/> of Intelligence
          </h1>
          <p class="text-xl md:text-2xl text-[#21275a]/60 max-w-2xl mx-auto mb-12 font-medium">
            At IIAT, we don't just teach AI. We build it. Explore our suite of AI agents and start your journey today.
          </p>
          <div class="flex flex-col items-center gap-4 animate-bounce mt-12">
            <span class="text-[10px] font-black uppercase tracking-widest text-[#21275a]/40">Scroll to Navigate</span>
            <svg class="w-6 h-6 text-[#e11d48]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
          </div>
        </div>
      </section>

      <!-- Agent Sections -->
      {[
        { 
          id: "resume", 
          num: "01", 
          title: "ResumeCraft Agent", 
          desc: "Optimize your professional profile with AI-driven scoring and keyword analysis tailored for high-growth tech roles.", 
          color: "red" 
        },
        { 
          id: "predict", 
          num: "02", 
          title: "CollegePredict Agent", 
          desc: "Data-driven admission forecasting. Analyze thousands of data points to find your perfect academic fit.", 
          color: "blue" 
        },
        { 
          id: "practice", 
          num: "03", 
          title: "EntrancePractice Agent", 
          desc: "Master engineering entrances with personalized practice sets that adapt to your learning pace and weak spots.", 
          color: "green" 
        },
        { 
          id: "interview", 
          num: "04", 
          title: "InterviewPrep Agent", 
          desc: "Practice with real-time AI interviewers. Get instant feedback on your technical knowledge and soft skills.", 
          color: "gold" 
        }
      ].map(agent => (
        <section id={agent.id} class="min-h-screen flex items-center justify-center px-6 md:px-24 snap-start border-b border-gray-50">
          <div class="max-w-7xl w-full grid md:grid-cols-2 gap-20 items-center">
            <div class="reveal opacity-0 translate-y-20 transition-all duration-1000">
              <div class="text-[120px] md:text-[200px] font-black text-[#21275a]/5 leading-none mb-4">{agent.num}</div>
              <h2 class="text-5xl md:text-7xl font-black text-[#21275a] mb-8 leading-tight">
                {agent.title}
              </h2>
              <p class="text-xl text-[#21275a]/60 mb-12 max-w-lg leading-relaxed font-medium">
                {agent.desc}
              </p>
              <a href="#" class="inline-flex items-center gap-4 text-[#e11d48] font-black uppercase tracking-widest group">
                Explore The Agent 
                <span class="w-12 h-px bg-[#e11d48] block transition-all group-hover:w-16"></span>
                <svg class="w-5 h-5 transition-transform group-hover:translate-x-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </a>
            </div>
            
            <div class="relative reveal opacity-0 scale-95 transition-all duration-1000 delay-300">
              <div class="aspect-square bg-white rounded-[60px] shadow-[0_40px_100px_rgba(0,0,0,0.05)] border border-gray-100 flex items-center justify-center p-12 overflow-hidden group">
                <div class="absolute inset-0 bg-gradient-to-br from-transparent to-[#e11d48]/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <!-- Placeholder for Agent Mascot/Illustration -->
                <div class="w-full h-full rounded-3xl bg-[#21275a]/5 flex flex-col items-center justify-center gap-6 group-hover:scale-105 transition-transform">
                  <svg class="w-24 h-24 text-[#e11d48]/20 group-hover:text-[#e11d48]/40 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                  <span class="text-[#21275a]/20 font-black uppercase tracking-widest text-xs">AI Agent Interface</span>
                </div>
              </div>
            </div>
          </div>
        </section>
      ))}

      <!-- Call to Action -->
      <section class="py-40 bg-[#21275a] text-white overflow-hidden relative">
        <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(white 0.5px, transparent 0.5px); background-size: 30px 30px;"></div>
        <div class="max-w-5xl mx-auto px-6 text-center relative z-10">
          <h2 class="text-5xl md:text-7xl font-black mb-12">Ready to Build <br/> The Agentic World?</h2>
          <p class="text-xl text-white/60 mb-16 max-w-2xl mx-auto font-medium">
            Join Semester 1 students who are already deploying AI models to production. Your future starts here.
          </p>
          <a href="/register" class="inline-block bg-[#e11d48] text-white font-black uppercase tracking-[0.2em] text-sm px-12 py-6 rounded-full hover:bg-white hover:text-[#21275a] transition-all transform hover:scale-110 shadow-2xl">
            Apply Now for 2026
          </a>
        </div>
      </section>

    </div>
  </div>

  <script>
    // Parallax & Reveal Logic
    const observerOptions = {
      threshold: 0.2
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('opacity-100', 'translate-y-0', 'scale-100');
          entry.target.classList.remove('opacity-0', 'translate-y-20', 'scale-95');
        }
      });
    }, observerOptions);

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Smooth Scroll Offset for Sticky Header
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          window.scrollTo({
            top: target.offsetTop - 80,
            behavior: 'smooth'
          });
        }
      });
    });
  </script>
</Layout>
