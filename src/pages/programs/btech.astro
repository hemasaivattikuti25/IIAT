---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="B.Tech Programs | IIAT Hyderabad">

  <!-- HERO -->
  <section class="bg-white pt-28 pb-16 px-6 border-b-2 border-[#21275a]/10">
    <div class="max-w-6xl mx-auto text-center">
      <span class="inline-block px-5 py-2 rounded-full bg-[#f7ba26]/20 text-[#21275a] text-sm font-bold uppercase tracking-wide mb-6">
        B.Tech Programs 2025–26
      </span>
      <h1 class="text-4xl md:text-6xl font-extrabold text-[#21275a] mb-6 leading-tight">
        Choose Your <span class="text-[#b00f1e]">B.Tech Specialization</span>
      </h1>
      <p class="text-xl text-[#21275a] max-w-3xl mx-auto mb-10">
        All programs are 4-year, full-time B.Tech degrees affiliated to a recognized university. No JEE required — admission via ROGER SAT.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#programs" class="inline-flex px-10 py-4 bg-[#b00f1e] text-white font-bold rounded-xl hover:bg-[#8a0c17] transition-colors">
          View All Programs
        </a>
        <a href="/#apply" class="inline-flex px-10 py-4 border-2 border-[#21275a] text-[#21275a] font-bold rounded-xl hover:bg-[#21275a] hover:text-white transition-colors">
          Register for ROGER SAT
        </a>
      </div>
    </div>
  </section>

  <!-- KEY FACTS -->
  <section class="bg-white py-12 px-6 border-b-2 border-[#21275a]/10">
    <div class="max-w-6xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div>
        <div class="text-3xl font-extrabold text-[#b00f1e] mb-1">4 Years</div>
        <div class="text-[#21275a] font-semibold">Full-Time B.Tech</div>
      </div>
      <div>
        <div class="text-3xl font-extrabold text-[#b00f1e] mb-1">6</div>
        <div class="text-[#21275a] font-semibold">Specializations</div>
      </div>
      <div>
        <div class="text-3xl font-extrabold text-[#b00f1e] mb-1">720</div>
        <div class="text-[#21275a] font-semibold">Total Seats</div>
      </div>
      <div>
        <div class="text-3xl font-extrabold text-[#b00f1e] mb-1">No JEE</div>
        <div class="text-[#21275a] font-semibold">Required</div>
      </div>
    </div>
  </section>

  <!-- PROGRAMS -->
  <section id="programs" class="bg-white py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-extrabold text-[#21275a] mb-4">All B.Tech Programs</h2>
        <div class="w-20 h-1.5 bg-[#f7ba26] mx-auto rounded-full"></div>
      </div>

      <div class="flex flex-col gap-8">

        <!-- Program 1 -->
        <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 md:p-10 bg-white hover:border-[#b00f1e] transition-colors">
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="inline-block px-3 py-1 bg-[#f7ba26]/20 text-[#21275a] text-xs font-bold rounded-full uppercase">Most Popular</span>
              </div>
              <h3 class="text-2xl md:text-3xl font-bold text-[#21275a] mb-2">B.Tech CSE (AI & Data Science)</h3>
              <p class="text-[#21275a] leading-relaxed max-w-2xl">
                Master artificial intelligence, machine learning, big data analytics, and data engineering. Build real-world AI products with industry mentors.
              </p>
              <div class="flex flex-wrap gap-3 mt-4">
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Machine Learning</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Big Data</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Deep Learning</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Data Engineering</span>
              </div>
            </div>
            <div class="flex flex-col items-start md:items-end gap-3">
              <div class="text-center md:text-right">
                <div class="text-3xl font-extrabold text-[#b00f1e]">180</div>
                <div class="text-[#21275a] font-semibold text-sm">Seats Available</div>
              </div>
              <a href="/#apply" class="inline-flex px-8 py-3 bg-[#b00f1e] text-white font-bold rounded-xl hover:bg-[#8a0c17] transition-colors whitespace-nowrap">
                Apply Now
              </a>
            </div>
          </div>
        </div>

        <!-- Program 2 -->
        <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 md:p-10 bg-white hover:border-[#b00f1e] transition-colors">
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex-1">
              <h3 class="text-2xl md:text-3xl font-bold text-[#21275a] mb-2">B.Tech CSE (AI & Machine Learning)</h3>
              <p class="text-[#21275a] leading-relaxed max-w-2xl">
                Deep dive into machine learning algorithms, neural networks, NLP, computer vision, and AI system design for enterprise applications.
              </p>
              <div class="flex flex-wrap gap-3 mt-4">
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Neural Networks</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">NLP</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Computer Vision</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">AI Systems</span>
              </div>
            </div>
            <div class="flex flex-col items-start md:items-end gap-3">
              <div class="text-center md:text-right">
                <div class="text-3xl font-extrabold text-[#b00f1e]">180</div>
                <div class="text-[#21275a] font-semibold text-sm">Seats Available</div>
              </div>
              <a href="/#apply" class="inline-flex px-8 py-3 bg-[#b00f1e] text-white font-bold rounded-xl hover:bg-[#8a0c17] transition-colors whitespace-nowrap">
                Apply Now
              </a>
            </div>
          </div>
        </div>

        <!-- Program 3 -->
        <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 md:p-10 bg-white hover:border-[#b00f1e] transition-colors">
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex-1">
              <h3 class="text-2xl md:text-3xl font-bold text-[#21275a] mb-2">B.Tech CSE (Core)</h3>
              <p class="text-[#21275a] leading-relaxed max-w-2xl">
                A strong foundation in computer science — algorithms, data structures, operating systems, databases, networks, and software engineering.
              </p>
              <div class="flex flex-wrap gap-3 mt-4">
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Algorithms</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">OS & Networks</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Software Engineering</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Databases</span>
              </div>
            </div>
            <div class="flex flex-col items-start md:items-end gap-3">
              <div class="text-center md:text-right">
                <div class="text-3xl font-extrabold text-[#b00f1e]">180</div>
                <div class="text-[#21275a] font-semibold text-sm">Seats Available</div>
              </div>
              <a href="/#apply" class="inline-flex px-8 py-3 bg-[#b00f1e] text-white font-bold rounded-xl hover:bg-[#8a0c17] transition-colors whitespace-nowrap">
                Apply Now
              </a>
            </div>
          </div>
        </div>

        <!-- Program 4 -->
        <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 md:p-10 bg-white hover:border-[#b00f1e] transition-colors">
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="inline-block px-3 py-1 bg-[#b00f1e]/10 text-[#b00f1e] text-xs font-bold rounded-full uppercase">Limited Seats</span>
              </div>
              <h3 class="text-2xl md:text-3xl font-bold text-[#21275a] mb-2">B.Tech CSE (FinTech & Artificial Intelligence)</h3>
              <p class="text-[#21275a] leading-relaxed max-w-2xl">
                Combine finance technology with AI — blockchain, digital payments, AI-driven financial systems, and algorithmic trading.
              </p>
              <div class="flex flex-wrap gap-3 mt-4">
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Blockchain</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Digital Payments</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Algo Trading</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">AI in Finance</span>
              </div>
            </div>
            <div class="flex flex-col items-start md:items-end gap-3">
              <div class="text-center md:text-right">
                <div class="text-3xl font-extrabold text-[#b00f1e]">60</div>
                <div class="text-[#21275a] font-semibold text-sm">Seats Available</div>
              </div>
              <a href="/#apply" class="inline-flex px-8 py-3 bg-[#b00f1e] text-white font-bold rounded-xl hover:bg-[#8a0c17] transition-colors whitespace-nowrap">
                Apply Now
              </a>
            </div>
          </div>
        </div>

        <!-- Program 5 -->
        <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 md:p-10 bg-white hover:border-[#b00f1e] transition-colors">
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="inline-block px-3 py-1 bg-[#b00f1e]/10 text-[#b00f1e] text-xs font-bold rounded-full uppercase">Limited Seats</span>
              </div>
              <h3 class="text-2xl md:text-3xl font-bold text-[#21275a] mb-2">B.Tech CSE (Cyber Security with AI/ML)</h3>
              <p class="text-[#21275a] leading-relaxed max-w-2xl">
                Defend digital infrastructure using AI-powered threat detection, ethical hacking, cryptography, and network security systems.
              </p>
              <div class="flex flex-wrap gap-3 mt-4">
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Ethical Hacking</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Cryptography</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Network Security</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Threat Detection</span>
              </div>
            </div>
            <div class="flex flex-col items-start md:items-end gap-3">
              <div class="text-center md:text-right">
                <div class="text-3xl font-extrabold text-[#b00f1e]">60</div>
                <div class="text-[#21275a] font-semibold text-sm">Seats Available</div>
              </div>
              <a href="/#apply" class="inline-flex px-8 py-3 bg-[#b00f1e] text-white font-bold rounded-xl hover:bg-[#8a0c17] transition-colors whitespace-nowrap">
                Apply Now
              </a>
            </div>
          </div>
        </div>

        <!-- Program 6 -->
        <div class="border-2 border-[#21275a]/10 rounded-2xl p-8 md:p-10 bg-white hover:border-[#b00f1e] transition-colors">
          <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-3">
                <span class="inline-block px-3 py-1 bg-[#b00f1e]/10 text-[#b00f1e] text-xs font-bold rounded-full uppercase">Limited Seats</span>
              </div>
              <h3 class="text-2xl md:text-3xl font-bold text-[#21275a] mb-2">B.Tech Biomedical Engineering, AI & Medical Robotics</h3>
              <p class="text-[#21275a] leading-relaxed max-w-2xl">
                The future of healthcare technology — medical imaging AI, surgical robotics, biosensors, and intelligent diagnostic systems.
              </p>
              <div class="flex flex-wrap gap-3 mt-4">
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Medical Imaging</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Surgical Robotics</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Biosensors</span>
                <span class="px-3 py-1 bg-[#21275a]/5 text-[#21275a] text-sm font-medium rounded-lg">Diagnostics AI</span>
              </div>
            </div>
            <div class="flex flex-col items-start md:items-end gap-3">
              <div class="text-center md:text-right">
                <div class="text-3xl font-extrabold text-[#b00f1e]">60</div>
                <div class="text-[#21275a] font-semibold text-sm">Seats Available</div>
              </div>
              <a href="/#apply" class="inline-flex px-8 py-3 bg-[#b00f1e] text-white font-bold rounded-xl hover:bg-[#8a0c17] transition-colors whitespace-nowrap">
                Apply Now
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ADMISSION PROCESS -->
  <section class="bg-white py-20 px-6 border-t-2 border-[#21275a]/10">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="text-4xl font-extrabold text-[#21275a] mb-4">Admission Process</h2>
        <div class="w-20 h-1.5 bg-[#f7ba26] mx-auto rounded-full mb-6"></div>
        <p class="text-xl text-[#21275a]">Simple, transparent, merit-based. No JEE required.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="text-center p-6 border-2 border-[#21275a]/10 rounded-2xl">
          <div class="w-14 h-14 bg-[#b00f1e] text-white text-2xl font-extrabold rounded-full flex items-center justify-center mx-auto mb-4">1</div>
          <h3 class="font-bold text-[#21275a] text-lg mb-2">Register</h3>
          <p class="text-[#21275a] text-sm">Sign up for ROGER SAT — free of cost, no JEE score needed</p>
        </div>
        <div class="text-center p-6 border-2 border-[#21275a]/10 rounded-2xl">
          <div class="w-14 h-14 bg-[#b00f1e] text-white text-2xl font-extrabold rounded-full flex items-center justify-center mx-auto mb-4">2</div>
          <h3 class="font-bold text-[#21275a] text-lg mb-2">Appear for SAT</h3>
          <p class="text-[#21275a] text-sm">Take the ROGER SAT aptitude test at an IIAT center</p>
        </div>
        <div class="text-center p-6 border-2 border-[#21275a]/10 rounded-2xl">
          <div class="w-14 h-14 bg-[#b00f1e] text-white text-2xl font-extrabold rounded-full flex items-center justify-center mx-auto mb-4">3</div>
          <h3 class="font-bold text-[#21275a] text-lg mb-2">Counselling</h3>
          <p class="text-[#21275a] text-sm">Select your program and specialization based on your score</p>
        </div>
        <div class="text-center p-6 border-2 border-[#21275a]/10 rounded-2xl">
          <div class="w-14 h-14 bg-[#b00f1e] text-white text-2xl font-extrabold rounded-full flex items-center justify-center mx-auto mb-4">4</div>
          <h3 class="font-bold text-[#21275a] text-lg mb-2">Join IIAT</h3>
          <p class="text-[#21275a] text-sm">Complete enrollment and begin your B.Tech journey</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-[#21275a] py-20 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-4xl font-extrabold text-white mb-6">Ready to Begin?</h2>
      <p class="text-xl text-gray-300 mb-10">Register for ROGER SAT — completely free, no JEE required.</p>
      <a href="mailto:info@iiath.com" class="inline-flex px-12 py-5 bg-[#f7ba26] text-[#21275a] font-extrabold text-lg rounded-xl hover:bg-[#fccf46] transition-colors">
        Contact Us — info@iiath.com
      </a>
    </div>
  </section>

</Layout>
