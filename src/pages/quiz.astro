<main class="flex-1 bg-[#f4f4ff] sm:pt-10 relative overflow-hidden"><div class="absolute inset-0 pointer-events-none"><div class="absolute -right-[200px] top-1/2 -translate-y-1/2 w-[535px] h-[450px] rotate-[270deg] scale-y-[-100%]"><img alt="" loading="lazy" decoding="async" class="object-contain" style="position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent" src="/73b0ad020632b6b1bf483e2355b8bd35e3003a1b.svg"/></div></div><div class="relative z-10 min-h-[calc(100vh-300px)] md:min-h-[calc(100vh-400px)] lg:min-h-[calc(100vh-500px)] flex items-center justify-center px-4 py-8 md:py-10 lg:py-12" style="opacity:0"><div class="bg-[#f4f4ff] rounded-[16px] md:rounded-[20px] lg:rounded-[24px] p-3 md:p-4 w-full max-w-[1000px]"><div class="flex flex-col gap-4 md:gap-6 lg:gap-8"><div class="flex justify-between items-start"><div class="flex flex-col gap-3"><h2 class="text-[18px] md:text-[20px] lg:text-[24px] font-semibold text-[#21275a] tracking-[-0.72px] md:tracking-[-0.8px] lg:tracking-[-0.96px]" style="font-family:&#x27;Plus Jakarta Sans&#x27;, sans-serif">Program Match Quiz</h2><div class="flex items-center gap-3"><span class="text-[14px] md:text-[16px] lg:text-[18px] text-gray-600" style="font-family:&#x27;Plus Jakarta Sans&#x27;, sans-serif">Quiz questions</span><div class="w-2 h-2 bg-#a08b6f rounded-full"></div><span class="text-[14px] md:text-[16px] lg:text-[18px] text-gray-600" style="font-family:&#x27;Plus Jakarta Sans&#x27;, sans-serif">6 Questions</span></div></div><button class="p-1.5 md:p-2 hover:bg-gray-100 rounded-lg transition-colors"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon" class="w-6 h-6 md:w-7 md:h-7 lg:w-8 lg:h-8 text-gray-700"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path></svg></button></div><div class="backdrop-blur-[22px] bg-[#1f3484]/40 rounded-[8px] md:rounded-[10px] border border-white p-4 md:p-6 lg:p-[24px]" style="opacity:0;transform:translateX(20px)"><div class="flex items-center gap-2 mb-4 md:mb-6 lg:mb-8 p-2 md:p-3 lg:p-4 rounded-[16px] md:rounded-[20px] lg:rounded-[24px]"><div class="flex-1"><div class="relative h-1.5 bg-gray-200 rounded-full overflow-hidden"><div class="absolute top-0 left-0 h-full bg-[var(--color-brand-600)] rounded-full" style="width:0px"></div></div></div><span class="text-[12px] md:text-[14px] lg:text-[16px] font-medium text-[#21275a]" style="font-family:&#x27;Plus Jakarta Sans&#x27;, sans-serif">1<!-- --> of 6</span></div><div class="mb-4 md:mb-6 lg:mb-8"><p class="text-[12px] md:text-[13px] lg:text-[14px] text-gray-600 mb-2 md:mb-3" style="font-family:&#x27;Plus Jakarta Sans&#x27;, sans-serif">Question 01</p><h3 class="text-[16px] md:text-[18px] lg:text-[20px] font-medium text-[#21275a] leading-[24px] md:leading-[27px] lg:leading-[30px]" style="font-family:&#x27;Plus Jakarta Sans&#x27;, sans-serif">What best describes your current journey?</h3></div><div class="mb-4 md:mb-6 lg:mb-8"><p class="text-[12px] md:text-[14px] lg:text-[16px] text-gray-600 mb-3 md:mb-4" style="font-family:&#x27;Plus Jakarta Sans&#x27;, sans-serif">Choose one from below</p><div class="grid grid-cols-1 md:grid-cols-2 gap-2 md:gap-3"><button class="p-3 md:p-[8px] rounded-[4px] border text-left transition-all bg-[#1f3484]/10 border-[var(--color-brand-700)]/20 text-[#21275a] hover:bg-[#1f3484]/20"><span class="text-[14px] md:text-[16px] lg:text-[18px] font-normal" style="font-family:&#x27;Plus Jakarta Sans&#x27;, sans-serif">I&#x27;m just starting out and exploring ideas</span></button><button class="p-3 md:p-[8px] rounded-[4px] border text-left transition-all bg-[#1f3484]/10 border-[var(--color-brand-700)]/20 text-[#21275a] hover:bg-[#1f3484]/20"><span class="text-[14px] md:text-[16px] lg:text-[18px] font-normal" style="font-family:&#x27;Plus Jakarta Sans&#x27;, sans-serif">I already have a project or startup</span></button><button class="p-3 md:p-[8px] rounded-[4px] border text-left transition-all bg-[#1f3484]/10 border-[var(--color-brand-700)]/20 text-[#21275a] hover:bg-[#1f3484]/20"><span class="text-[14px] md:text-[16px] lg:text-[18px] font-normal" style="font-family:&#x27;Plus Jakarta Sans&#x27;, sans-serif">I&#x27;m looking to level up professionally</span></button><button class="p-3 md:p-[8px] rounded-[4px] border text-left transition-all bg-[#1f3484]/10 border-[var(--color-brand-700)]/20 text-[#21275a] hover:bg-[#1f3484]/20"><span class="text-[14px] md:text-[16px] lg:text-[18px] font-normal" style="font-family:&#x27;Plus Jakarta Sans&#x27;, sans-serif">I want to build but don&#x27;t know where to begin</span></button></div></div></div><div class="flex justify-between items-center"><div></div><button disabled="" class="flex items-center gap-1.5 md:gap-2 px-3 md:px-4 py-1.5 md:py-2 rounded-[6px] md:rounded-[8px] border transition-colors border-#a08b6f bg-gray-100 cursor-not-allowed opacity-50"><span class="text-[14px] md:text-[16px] lg:text-[18px] font-medium text-#a08b6f" style="font-family:&#x27;Plus Jakarta Sans&#x27;, sans-serif">Next</span><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true" data-slot="icon" class="w-4 h-4 md:w-5 md:h-5 text-#a08b6f"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"></path></svg></button></div></div></div></div>
