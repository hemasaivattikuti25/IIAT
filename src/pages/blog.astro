            <style>
                .glossy-category-card {
                    height: 100px;
                    width: 200px;
                    border-radius: 15px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    position: relative;
                    overflow: hidden;
                    box-shadow: 0 8px 20px rgba(30, 46, 104, 0.3);
                    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                    z-index: 1;
                    background: linear-gradient(135deg, #b73400 10%, #1e2e68 100%);
                    margin: 0 auto;
                }
                .glossy-category-card::before {
                    content: '';
                    position: absolute;
                    top: 0;
                    left: 0;
                    right: 0;
                    height: 60%;
                    background: linear-gradient(to bottom,
                            rgba(255, 255, 255, 0.3) 0%,
                            rgba(255, 255, 255, 0.15) 30%,
                            rgba(255, 255, 255, 0.05) 60%,
                            rgba(255, 255, 255, 0) 100%);
                    border-radius: 15px 15px 100px 100px;
                    z-index: 1;
                }
                .glossy-category-card::after {
                    content: '';
                    position: absolute;
                    top: -3px;
                    left: -3px;
                    right: -3px;
                    bottom: -3px;
                    background: linear-gradient(45deg,
                            rgba(255, 255, 255, 0) 0%,
                            rgba(255, 255, 255, 0.8) 50%,
                            rgba(255, 255, 255, 0) 100%);
                    border-radius: 18px;
                    z-index: -1;
                    opacity: 0;
                    transition: opacity 0.3s ease;
                    animation: glow 4s infinite linear;
                }
                @keyframes glow {
                    0%, 100% { opacity: 0.3; box-shadow: 0 0 10px rgba(255, 255, 255, 0.5); }
                    25% { opacity: 0.5; box-shadow: 0 0 20px rgba(255, 255, 255, 0.5); }
                    50% { opacity: 0.8; box-shadow: 0 0 30px rgba(255, 255, 255, 0.8); }
                    75% { opacity: 0.5; box-shadow: 0 0 20px rgba(255, 255, 255, 0.5); }
                }
                .glossy-category-card:hover {
                    transform: translateY(-8px) scale(1.03);
                    box-shadow: 0 15px 30px rgba(30, 46, 104, 0.6);
                }
                .glossy-category-content {
                    text-align: center;
                    padding: 20px;
                    width: 100%;
                    z-index: 2;
                    position: relative;
                }
                .glossy-category-content h5 {
                    font-weight: 600;
                    font-size: 1.2rem;
                    text-shadow: 0 2px 4px rgba(33, 39, 90, 0.3);
                    margin-bottom: 10px;
                }
                .category-count {
                    display: inline-block;
                    background-color: rgba(255, 255, 255, 0.15);
                    color: white;
                    padding: 5px 12px;
                    border-radius: 20px;
                    font-size: 0.85rem;
                    margin-top: 10px;
                    font-weight: 500;
                    backdrop-filter: blur(5px);
                    box-shadow: 0 2px 8px rgba(33, 39, 90, 0.2);
                    text-shadow: 0 1px 2px rgba(33, 39, 90, 0.3);
                    transition: all 0.3s ease;
                }
                .glossy-category-card:hover .category-count {
                    background-color: rgba(255, 255, 255, 0.25);
                    transform: scale(1.05);
                }
                .category-swiper { padding: 30px 50px; position: relative; }
                .category-swiper .swiper-button-next,
                .category-swiper .swiper-button-prev {
                    color: #1e2e68;
                    background-color: rgba(255, 255, 255, 0.7);
                    width: 40px;
                    height: 40px;
                    border-radius: 50%;
                    box-shadow: 0 4px 10px rgba(33, 39, 90, 0.1);
                    transition: all 0.3s ease;
                }
                .category-swiper .swiper-button-next:hover,
                .category-swiper .swiper-button-prev:hover {
                    background-color: #ffffff;
                    transform: scale(1.1);
                }
                .category-swiper .swiper-button-next:after,
                .category-swiper .swiper-button-prev:after { font-size: 18px; font-weight: bold; }
                .category-swiper .swiper-pagination-bullet {
                    width: 10px;
                    height: 10px;
                    background-color: rgba(30, 46, 104, 0.3);
                    opacity: 1;
                    transition: all 0.3s ease;
                }
                .category-swiper .swiper-pagination-bullet-active {
                    background-color: #b73400;
                    width: 30px;
                    border-radius: 5px;
                }
                .swiper-container-horizontal>.swiper-scrollbar { display: none; }
            </style>

            <script>
                document.addEventListener('DOMContentLoaded', function () {
                    new Swiper('.category-swiper', {
                        slidesPerView: 1,
                        spaceBetween: 30,
                        loop: true,
                        grabCursor: true,
                        centeredSlides: true,
                        speed: 800,
                        effect: 'coverflow',
                        coverflowEffect: {
                            rotate: 0,
                            stretch: 0,
                            depth: 100,
                            modifier: 2,
                            slideShadows: false,
                        },
                        autoplay: {
                            delay: 3000,
                            disableOnInteraction: false,
                        },
                        pagination: {
                            el: '.swiper-pagination',
                            clickable: true,
                        },
                        navigation: {
                            nextEl: '.swiper-button-next',
                            prevEl: '.swiper-button-prev',
                        },
                        breakpoints: {
                            576: { slidesPerView: 2, },
                            768: { slidesPerView: 3, },
                            992: { slidesPerView: 4, }
                        }
                    });
                });
            </script>

