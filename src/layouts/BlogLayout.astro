---
/**
 * BlogLayout.astro - Standalone layout for the IIAT Hyderabad blog.
 * This is a completely separate layout from the main site because the blog
 * uses Bootstrap 5, different fonts (Inter, Playfair Display), and its own
 * header/footer (originally served from blog.iiath.com).
 */
---

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/favicon.ico">

    <slot name="head" />

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <!-- AOS Animation Library -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <!-- Swiper CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <style>
        :root {
            --light-bg: rgba(255, 255, 255, 0.95);
            --primary-color: #d46324;
            --secondary-color: #1e2e68;
            --accent-color: #f5c344;
            --text-dark: #2d3436;
            --text-muted: #6c757d;
            --border-radius: 15px;
            --transition: all 0.3s ease;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            background-color: #f8f9fa;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        main {
            flex: 1 0 auto;
        }

        img {
            max-width: 100%;
            height: auto;
        }

        h1, .h1 { font-size: calc(1.5rem + 1.5vw); }
        h2, .h2 { font-size: calc(1.325rem + 0.9vw); }
        h3, .h3 { font-size: calc(1.25rem + 0.6vw); }
        h4, .h4 { font-size: calc(1.175rem + 0.3vw); }

        p, .card-text { line-height: 1.7; }

        .navbar {
            background: var(--secondary-color);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            box-shadow: 0 2px 10px rgba(33, 39, 90, 0.1);
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
        }
        .navbar .navbar-brand { font-weight: 700; }
        .navbar .nav-link {
            color: #fcfbfb;
            font-weight: 500;
            position: relative;
            transition: color 0.3s ease;
            padding: 0.5rem 0.75rem;
        }
        .navbar .nav-link:hover { color: #fcfbfb; }
        .navbar .nav-link::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: 0;
            left: 0;
            background-color: #fcfbfb;
            transition: width 0.3s ease;
        }
        .navbar .nav-link:hover::after { width: 100%; }

        .dropdown-menu {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: none;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(33, 39, 90, 0.1);
            margin-top: 0.5rem !important;
        }
        .programs-menu { min-width: 800px; }

        .card {
            transition: all 0.3s ease;
            border-radius: var(--border-radius);
            overflow: hidden;
            box-shadow: 0 4px 12px rgba(33, 39, 90, 0.05);
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 24px rgba(33, 39, 90, 0.1);
        }

        .offcanvas {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }
        .list-group-item {
            background: transparent;
            transition: all 0.3s ease;
        }
        .list-group-item:hover {
            background: rgba(0, 123, 255, 0.05);
            color: var(--primary-color);
        }
        .list-group-item.bg-light { background: rgba(33, 39, 90, 0.02) !important; }

        .main-content { padding-top: 76px; }

        .filter-container {
            background-color: white;
            border-radius: var(--border-radius);
            box-shadow: 0 4px 12px rgba(33, 39, 90, 0.05);
            padding: 20px;
            margin-bottom: 30px;
        }
        .filter-badge {
            background-color: var(--accent-color);
            color: var(--text-dark);
            font-weight: 500;
            padding: 8px 15px;
            border-radius: 30px;
            margin-right: 8px;
            margin-bottom: 8px;
            display: inline-block;
            cursor: pointer;
            transition: var(--transition);
        }
        .filter-badge:hover, .filter-badge.active {
            background-color: var(--primary-color);
            color: white;
        }
        .filter-btn {
            background-color: var(--secondary-color);
            color: white;
            border: none;
            padding: 8px 20px;
            border-radius: 30px;
            font-weight: 500;
            transition: var(--transition);
        }
        .filter-btn:hover {
            background-color: var(--primary-color);
            transform: translateY(-2px);
        }
        .search-input {
            border-radius: 30px;
            padding-left: 15px;
            border: 1px solid #e9ecef;
            transition: var(--transition);
        }
        .search-input:focus {
            box-shadow: 0 0 0 0.25rem rgba(35, 57, 158, 0.15);
            border-color: var(--secondary-color);
        }

        @media (max-width: 991.98px) {
            .programs-menu { min-width: auto; }
            .navbar-toggler:focus { box-shadow: none; }
            .main-content { padding-top: 62px; }
        }

        .blog-card {
            height: 100%;
            display: flex;
            flex-direction: column;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .blog-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(33, 39, 90, 0.1);
        }
        .blog-card .card-body { flex: 1; padding: 1.5rem; }
        .blog-card .card-img-top {
            height: 200px;
            object-fit: cover;
            border-top-left-radius: var(--border-radius);
            border-top-right-radius: var(--border-radius);
        }
        .blog-tag {
            background-color: var(--accent-color);
            color: var(--text-dark);
            font-size: 0.75rem;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 20px;
            margin-right: 4px;
            margin-bottom: 5px;
            display: inline-block;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .blog-tag:hover {
            background-color: var(--primary-color);
            color: white !important;
            transform: translateY(-2px);
        }
        .blog-category {
            background-color: var(--secondary-color);
            color: white;
            font-size: 0.75rem;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 20px;
            margin-right: 4px;
            margin-bottom: 5px;
            display: inline-block;
        }

        @media (max-width: 767.98px) {
            .article-content { font-size: 1rem !important; line-height: 1.7 !important; }
            .article-content h2, .article-content h3 { font-size: calc(1.2rem + 0.6vw) !important; }
            .card-title { font-size: 1.15rem; }
            .container { padding-left: 20px; padding-right: 20px; }
        }

        .footer {
            background-color: var(--secondary-color) !important;
            color: #fff;
            padding: 4rem 0;
            margin-top: auto;
        }
        .footer h5 { font-size: 1.25rem; font-weight: 600; margin-bottom: 1.5rem; }
        .footer-links a {
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            transition: color 0.3s ease;
            font-size: 1rem;
            display: inline-block;
        }
        .footer-links a:hover { color: #fff; }
        .social-icons { display: flex; align-items: center; }
        .social-icon {
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            transition: color 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .social-icon:hover { color: #fff; }

        .apply-now-btn {
            background-color: #d46324;
            color: white;
            border-radius: 30px;
            padding: 8px 20px;
            font-weight: 500;
            transition: all 0.3s ease;
            border: none;
        }
        .apply-now-btn:hover {
            transform: translateY(-2px);
            background-color: #e05e00;
            color: white;
            box-shadow: 0 4px 10px rgba(251, 105, 0, 0.3);
        }
    </style>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
        rel="stylesheet">
</head>

<body>
    <!-- Desktop Header -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand py-2" href="/">
                <img src="/static/img/logo/logo-light.png" alt="IIAT Hyderabad" style="width: 100px;">
            </a>
            <button class="navbar-toggler shadow-none border-0 bg-white" type="button" data-bs-toggle="offcanvas"
                data-bs-target="#mobileMenu" aria-controls="mobileMenu">
                <i class="bi bi-list fs-1"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-auto align-items-center gap-1">
                    <li class="nav-item"><a class="nav-link px-3" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="https://iiath.com/programs/ug">Explore Programs</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="https://iiath.com/partnership">Partners</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="https://iiath.com/campus-life">Campus Life</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="https://iiath.com/events/">Events</a></li>
                    <li class="nav-item ms-2">
                        <a href="https://iiath.com/apply-cohort-25/" class="btn apply-now-btn">
                            Apply Now <i class="bi bi-arrow-right"></i>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Mobile Menu -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="mobileMenu" aria-labelledby="mobileMenuLabel">
        <div class="offcanvas-header border-bottom">
            <img src="/static/img/logo/logo-dark.png" alt="IIAT Hyderabad" height="35">
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-0">
            <div class="p-4">
                <div class="list-group list-group-flush">
                    <a href="/" class="list-group-item list-group-item-action border-0 px-3 py-3">Home</a>
                    <a href="https://iiath.com/programs/ug" class="list-group-item list-group-item-action border-0 px-3 py-3">Explore Programs</a>
                    <a href="https://iiath.com/partnership" class="list-group-item list-group-item-action border-0 px-3 py-3">Partners</a>
                    <a href="https://iiath.com/campus-life" class="list-group-item list-group-item-action border-0 px-3 py-3">Campus Life</a>
                    <a href="https://iiath.com/events/" class="list-group-item list-group-item-action border-0 px-3 py-3">Events</a>
                    <div class="mt-3">
                        <a href="https://iiath.com/apply-cohort-25/" class="btn apply-now-btn w-100">
                            Apply Now <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <slot />

    <footer class="footer bg-white text-[#f7ba26] py-5 mt-4">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4 mb-lg-0">
                    <a href="/" class="d-inline-block mb-4">
                        <img src="/static/img/logo/logo-light.png" alt="IIAT Hyderabad" height="40">
                    </a>
                    <p class="mb-4 text-[#f7ba26]-50">
                        We are dedicated to empowering future business leaders through hands-on education, innovation,
                        and real-world application. Join us to transform your entrepreneurial vision into impactful ventures.
                    </p>
                    <div class="social-icons">
                        <a href="https://www.instagram.com/iiath.school/#" class="social-icon me-3">
                            <i class="bi bi-instagram fs-5"></i>
                        </a>
                        <a href="https://www.facebook.com/people/IIAT-School-of-Entrepreneurship/61568074757397/?mibextid=LQQJ4d&rdid=E7pExsyIBIKaNCjN&share_url=https%3A%2F%2Fwww.facebook.com%2Fshare%2F15Neqzdzdc%2F%3Fmibextid%3DLQQJ4d"
                            class="social-icon me-3">
                            <i class="bi bi-facebook fs-5"></i>
                        </a>
                        <a href="https://www.linkedin.com/company/iiath-school/" class="social-icon">
                            <i class="bi bi-linkedin fs-5"></i>
                        </a>
                    </div>
                </div>
                <div class="col-lg-2 offset-lg-1 mb-4 mb-lg-0">
                    <h5 class="text-[#f7ba26] mb-4">Quick Links</h5>
                    <ul class="list-unstyled footer-links">
                        <li class="mb-2"><a href="/">Blogs</a></li>
                        <li class="mb-2"><a href="https://iiath.com/programs/ug">UG Program</a></li>
                        <li class="mb-2"><a href="https://iiath.com/programs/k12-seed">Seed Program</a></li>
                        <li class="mb-2"><a href="https://iiath.com/programs/lead">Lead Program</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 mb-4 mb-lg-0">
                    <h5 class="text-[#f7ba26] mb-4">Resources</h5>
                    <ul class="list-unstyled footer-links">
                        <li class="mb-2"><a href="/">Blog</a></li>
                        <li class="mb-2"><a href="https://iiath.com/events/">Events</a></li>
                    </ul>
                </div>
                <div class="col-lg-2">
                    <h5 class="text-[#f7ba26] mb-4">Company</h5>
                    <ul class="list-unstyled footer-links">
                        <li class="mb-2"><a href="/how-to-create/">How to Create a Blog</a></li>
                        <li class="mb-2"><a href="/how-it-works/">How It Works</a></li>
                        <li class="mb-2"><a href="/login/"> Author Login</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AOS Animation Library -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        AOS.init();
        if (window.innerWidth > 991.98) {
            document.querySelectorAll('.dropdown').forEach(function (dropdown) {
                dropdown.addEventListener('mouseenter', function () {
                    this.querySelector('.dropdown-toggle').click();
                });
                dropdown.addEventListener('mouseleave', function () {
                    this.querySelector('.dropdown-toggle').click();
                });
            });
        }
        document.addEventListener('DOMContentLoaded', function () {
            const filterBadges = document.querySelectorAll('.filter-badge');
            filterBadges.forEach(badge => {
                badge.addEventListener('click', function () {
                    this.classList.toggle('active');
                });
            });
        });
    </script>
</body>

</html>
