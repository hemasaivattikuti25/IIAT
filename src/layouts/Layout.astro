<script>
  // ===== 1. SCROLL-TRIGGERED REVEAL ANIMATIONS =====
  (function initRevealAnimations() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          el.style.transition = 'opacity 0.6s ease-out, transform 0.6s ease-out';
          el.style.opacity = '1';
          el.style.transform = 'none';
          observer.unobserve(el);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    // Observe elements that have inline opacity:1 with transform
    function observeRevealElements() {
      document.querySelectorAll('[style]').forEach(el => {
        const style = el.getAttribute('style') || '';
        if (style.includes('opacity:1') && (style.includes('translate') || style.includes('scale'))) {
          // Skip elements inside <head> or script tags
          if (el.closest('head') || el.tagName === 'SCRIPT') return;
          observer.observe(el);
        }
      });
    }

    // Run on load and after any dynamic content changes
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', observeRevealElements);
    } else {
      observeRevealElements();
    }
  })();

  // ===== 2. HEADER SCROLL BACKGROUND TOGGLE =====
  (function initHeaderScroll() {
    const header = document.querySelector('header');
    if (!header) return;

    let lastScrollY = 0;
    const SCROLL_THRESHOLD = 50;

    function updateHeader() {
      const scrollY = window.scrollY;
      if (scrollY > SCROLL_THRESHOLD) {
        header.classList.add('header-scrolled');
        // Removed class toggle logic
      } else {
        header.classList.remove('header-scrolled');
        // Removed class toggle logic
      }
      lastScrollY = scrollY;
    }

    window.addEventListener('scroll', updateHeader, { passive: true });
    updateHeader();
  })();

  // ===== 3. MOBILE MENU TOGGLE =====
  (function initMobileMenu() {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const closeBtn = document.getElementById('mobile-menu-close');
    const mobileMenu = document.getElementById('mobile-menu');
    if (!toggleBtn || !mobileMenu) return;

    function openMenu() {
      mobileMenu.classList.remove('translate-x-full');
      mobileMenu.classList.add('translate-x-0');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      mobileMenu.classList.add('translate-x-full');
      mobileMenu.classList.remove('translate-x-0');
      document.body.style.overflow = '';
    }

    toggleBtn.addEventListener('click', openMenu);
    if (closeBtn) closeBtn.addEventListener('click', closeMenu);

    // Close on link click (but not on details/summary)
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  })();

  // ===== 4. DESKTOP DROPDOWN MENUS =====
  (function initDropdowns() {
    const containers = document.querySelectorAll('.dropdown-container[data-dropdown]');
    let activeDropdown = null;
    let hoverTimeout = null;

    containers.forEach(container => {
      const trigger = container.querySelector('.dropdown-trigger');
      const panel = container.querySelector('.dropdown-panel');
      const chevron = container.querySelector('.dropdown-chevron');
      if (!trigger || !panel) return;

      function open() {
        // Close any other open dropdown
        if (activeDropdown && activeDropdown !== container) {
          closeDropdown(activeDropdown);
        }
        clearTimeout(hoverTimeout);
        panel.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
        panel.classList.add('opacity-100', 'visible', 'pointer-events-auto');
        if (chevron) chevron.style.transform = 'rotate(180deg)';
        activeDropdown = container;
      }

      function close() {
        panel.classList.add('opacity-0', 'invisible', 'pointer-events-none');
        panel.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
        if (chevron) chevron.style.transform = '';
        if (activeDropdown === container) activeDropdown = null;
      }

      // Hover behavior on desktop
      container.addEventListener('mouseenter', () => {
        if (window.innerWidth >= 1024) open();
      });

      container.addEventListener('mouseleave', () => {
        if (window.innerWidth >= 1024) {
          hoverTimeout = setTimeout(() => close(), 150);
        }
      });

      // Click behavior (for touch devices using desktop layout)
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        if (panel.classList.contains('opacity-0')) {
          open();
        } else {
          close();
        }
      });
    });

    function closeDropdown(container) {
      const panel = container.querySelector('.dropdown-panel');
      const chevron = container.querySelector('.dropdown-chevron');
      if (panel) {
        panel.classList.add('opacity-0', 'invisible', 'pointer-events-none');
        panel.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
      }
      if (chevron) chevron.style.transform = '';
      if (activeDropdown === container) activeDropdown = null;
    }

    // Close dropdowns when clicking outside
    document.addEventListener('click', (e) => {
      if (activeDropdown && !activeDropdown.contains(e.target)) {
        closeDropdown(activeDropdown);
      }
    });
  })();

  // ===== 5. CALENDLY POPUP TRIGGERS =====
  (function initCalendly() {
    // Attach to any button/link with data-calendly-url
    document.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-calendly-url]');
      if (btn && typeof Calendly !== 'undefined') {
        e.preventDefault();
        Calendly.initPopupWidget({ url: btn.getAttribute('data-calendly-url') });
      }
    });
  })();

  // ===== 6. HERO IMAGE SLIDESHOW =====
  (function initHeroSlideshow() {
    // Find hero slideshow containers (multiple absolute-positioned images with transition-opacity)
    const heroContainers = document.querySelectorAll('.relative.w-full.pt-20.overflow-hidden > .absolute.inset-0.z-0');
    heroContainers.forEach(container => {
      const slides = container.querySelectorAll(':scope > .absolute.inset-0.transition-opacity');
      if (slides.length <= 1) return;

      let currentIndex = 0;
      setInterval(() => {
        slides[currentIndex].style.opacity = '0';
        currentIndex = (currentIndex + 1) % slides.length;
        slides[currentIndex].style.opacity = '1';
      }, 5000);
    });
  })();

  // ===== 7. STICKY SECTION NAV SCROLL-SPY =====
  (function initSectionNav() {
    const navButtons = document.querySelectorAll('button[data-section]');
    if (navButtons.length === 0) return;

    // Click handler: scroll to section
    navButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const sectionId = btn.getAttribute('data-section');
        const section = document.getElementById(sectionId);
        if (section) {
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Scroll-spy: highlight active section button
    const sectionIds = Array.from(navButtons).map(btn => btn.getAttribute('data-section'));
    const sections = sectionIds.map(id => document.getElementById(id)).filter(Boolean);

    if (sections.length === 0) return;

    const spyObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          navButtons.forEach(btn => {
            const underline = btn.querySelector('span');
            if (btn.getAttribute('data-section') === id) {
              btn.classList.add('text-gray-200');
              btn.classList.remove('text-[#21275a]');
              if (underline) {
                underline.classList.remove('opacity-0', 'scale-x-0');
                underline.classList.add('opacity-100', 'scale-x-100');
              }
            } else {
              btn.classList.remove('text-gray-200');
              btn.classList.add('text-[#21275a]');
              if (underline) {
                underline.classList.add('opacity-0', 'scale-x-0');
                underline.classList.remove('opacity-100', 'scale-x-100');
              }
            }
          });
        }
      });
    }, { threshold: 0.3, rootMargin: '-80px 0px -50% 0px' });

    sections.forEach(section => spyObserver.observe(section));
  })();

  // ===== 8. HORIZONTAL SCROLL CAROUSEL =====
  (function initCarousels() {
    document.querySelectorAll('.overflow-x-auto.scroll-smooth.snap-x').forEach(scrollContainer => {
      const parent = scrollContainer.closest('.relative');
      if (!parent) return;

      const prevBtn = parent.querySelector('button:has(svg path[d*="15.75"])');
      const nextBtn = parent.querySelector('button:has(svg path[d*="8.25"])');
      if (!prevBtn && !nextBtn) return;

      const scrollAmount = scrollContainer.offsetWidth * 0.8;

      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          scrollContainer.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          scrollContainer.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        });
      }
    });
  })();

  // ===== 9. FAQ ACCORDIONS =====
  // Note: Most FAQ sections use native <details>/<summary> which work without JS.
  // This handles any custom accordion patterns with data-accordion attributes.
  (function initAccordions() {
    document.querySelectorAll('[data-accordion-trigger]').forEach(trigger => {
      trigger.addEventListener('click', () => {
        const content = trigger.nextElementSibling;
        const icon = trigger.querySelector('[data-accordion-icon]');
        if (!content) return;

        const isOpen = content.style.maxHeight && content.style.maxHeight !== '0px';
        if (isOpen) {
          content.style.maxHeight = '0px';
          content.style.overflow = 'hidden';
          if (icon) icon.style.transform = '';
        } else {
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.overflow = 'hidden';
          if (icon) icon.style.transform = 'rotate(180deg)';
        }
      });
    });
  })();

  // ===== 10. VIDEO PLAY BUTTON =====
  (function initVideoPlayers() {
    document.querySelectorAll('[data-video-play]').forEach(btn => {
      btn.addEventListener('click', () => {
        const videoUrl = btn.getAttribute('data-video-url');
        const container = btn.closest('.relative');
        if (!container || !videoUrl) return;

        // Replace thumbnail with iframe
        const iframe = document.createElement('iframe');
        iframe.src = videoUrl + (videoUrl.includes('?') ? '&' : '?') + 'autoplay=1';
        iframe.className = 'absolute inset-0 w-full h-full';
        iframe.setAttribute('frameborder', '0');
        iframe.setAttribute('allow', 'autoplay; encrypted-media');
        iframe.setAttribute('allowfullscreen', '');

        // Hide thumbnail and play button
        btn.style.display = 'none';
        const thumbnail = container.querySelector('img');
        if (thumbnail) thumbnail.style.display = 'none';

        container.appendChild(iframe);
      });
    });
  })();
</script>

