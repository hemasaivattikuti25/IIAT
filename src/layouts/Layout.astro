---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "IIAT Hyderabad — Indian Institute of Advanced Technologies. Where Curiosity Becomes Capability." } = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/logo-iiat.svg" />
  <meta name="generator" content={Astro.generator} />
</head>
<body class="bg-white text-[#21275a]">

  <!-- Announcement Ticker -->
  <div class="bg-[#21275a] overflow-hidden py-2">
    <div class="flex whitespace-nowrap">
      <span class="animate-ticker inline-block text-white text-xs font-bold tracking-widest uppercase px-4">
        Our ISAT (IIAT Scholarship Assessment Test) is now live &bull; Register Now — Free &bull; No JEE Required &bull; 6 Specialized B.Tech Programs &bull; 500+ Students Enrolled &bull; Our ISAT is now live &bull; Register Now — Free &bull; No JEE Required &bull; 6 Specialized B.Tech Programs &bull; 500+ Students Enrolled &bull; Our ISAT is now live &bull; Register Now — Free &bull; No JEE Required &bull; 6 Specialized B.Tech Programs &bull; 500+ Students Enrolled &bull;&nbsp;
      </span>
    </div>
  </div>

  <!-- Navbar -->
  <nav id="navbar" class="sticky top-0 z-50 bg-white border-b border-[#21275a]/10 px-6 lg:px-16 py-4 flex items-center justify-between transition-shadow duration-300">
    <a href="/" class="flex items-center gap-3">
      <img src="/logo-iiat.svg" alt="IIAT Hyderabad" class="h-10 w-auto" onerror="this.style.display='none'" />
      <div>
        <div class="font-black text-xl text-[#21275a] leading-none">IIAT</div>
        <div class="text-[10px] font-bold uppercase tracking-widest text-[#b00f1e]">Hyderabad</div>
      </div>
    </a>

    <div class="hidden lg:flex items-center gap-8">
      <div class="relative group">
        <button class="flex items-center gap-1 font-bold text-sm text-[#21275a] hover:text-[#b00f1e] transition-colors">
          Programs
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="absolute top-full left-0 mt-2 w-72 bg-white rounded-2xl shadow-2xl border border-[#21275a]/5 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 p-2">
          <a href="/programs/btech-ai-ds" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-[#21275a]/5 transition-colors">
            <div class="w-8 h-8 rounded-lg bg-[#b00f1e]/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-[#b00f1e]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
            </div>
            <div><div class="font-bold text-sm text-[#21275a]">AI & Data Science</div><div class="text-xs text-[#21275a]/60">B.Tech CSE — 180 Seats</div></div>
          </a>
          <a href="/programs/btech-fintech" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-[#21275a]/5 transition-colors">
            <div class="w-8 h-8 rounded-lg bg-[#b00f1e]/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-[#b00f1e]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2"/></svg>
            </div>
            <div><div class="font-bold text-sm text-[#21275a]">FinTech & AI</div><div class="text-xs text-[#21275a]/60">B.Tech CSE — 60 Seats</div></div>
          </a>
          <a href="/programs/btech-cyber" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-[#21275a]/5 transition-colors">
            <div class="w-8 h-8 rounded-lg bg-[#b00f1e]/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-[#b00f1e]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <div><div class="font-bold text-sm text-[#21275a]">Cyber Security</div><div class="text-xs text-[#21275a]/60">B.Tech CSE — 60 Seats</div></div>
          </a>
          <a href="/programs/btech-core" class="flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-[#21275a]/5 transition-colors">
            <div class="w-8 h-8 rounded-lg bg-[#b00f1e]/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-[#b00f1e]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
            </div>
            <div><div class="font-bold text-sm text-[#21275a]">Core CSE</div><div class="text-xs text-[#21275a]/60">B.Tech — 180 Seats</div></div>
          </a>
        </div>
      </div>
      <a href="/campus" class="font-bold text-sm text-[#21275a] hover:text-[#b00f1e] transition-colors">Campus</a>
      <a href="/about" class="font-bold text-sm text-[#21275a] hover:text-[#b00f1e] transition-colors">About</a>
      <a href="/faq" class="font-bold text-sm text-[#21275a] hover:text-[#b00f1e] transition-colors">FAQs</a>
      <a href="/contact" class="font-bold text-sm border-2 border-[#21275a] text-[#21275a] px-5 py-2 rounded-lg hover:border-[#b00f1e] hover:text-[#b00f1e] transition-all">Download Brochure</a>
      <a href="/register" class="font-extrabold text-sm bg-[#b00f1e] text-white px-6 py-2.5 rounded-lg hover:bg-[#8a0c17] transition-all transform hover:scale-105">
        Register for ISAT
      </a>
    </div>

    <button id="mobile-menu-btn" class="lg:hidden text-[#21275a]">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-b border-[#21275a]/10 px-6 py-6 space-y-4">
    <a href="/programs" class="block font-bold text-[#21275a] py-2 border-b border-[#21275a]/5">Programs</a>
    <a href="/campus" class="block font-bold text-[#21275a] py-2 border-b border-[#21275a]/5">Campus</a>
    <a href="/about" class="block font-bold text-[#21275a] py-2 border-b border-[#21275a]/5">About</a>
    <a href="/faq" class="block font-bold text-[#21275a] py-2 border-b border-[#21275a]/5">FAQs</a>
    <a href="/register" class="block text-center bg-[#b00f1e] text-white font-extrabold py-3 rounded-lg">Register for ISAT — Free</a>
  </div>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-[#21275a] text-white pt-20 pb-10 px-6 lg:px-16">
    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      <div class="space-y-5">
        <div>
          <div class="font-black text-3xl text-white">IIAT</div>
          <div class="text-[#f7ba26] font-bold text-xs uppercase tracking-widest">Hyderabad</div>
        </div>
        <p class="text-white/60 text-sm leading-relaxed">Indian Institute of Advanced Technologies — Where Curiosity Becomes Capability. India's most industry-integrated B.Tech program.</p>
        <div class="flex gap-3">
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#b00f1e] transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951z"/></svg></a>
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#b00f1e] transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.917 3.917 0 0 0-1.417.923A3.927 3.927 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.916 3.916 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.926 3.926 0 0 0-.923-1.417A3.911 3.911 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0h.003zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599.28.28.453.546.598.92.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.47 2.47 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.478 2.478 0 0 1-.92-.598 2.48 2.48 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233 0-2.136.008-2.388.046-3.231.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92.28-.28.546-.453.92-.598.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045v.002zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92zm-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217zm0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334z"/></svg></a>
          <a href="#" class="w-9 h-9 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#b00f1e] transition-colors"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"/></svg></a>
        </div>
      </div>

      <div>
        <h4 class="font-extrabold text-lg mb-6">Programs</h4>
        <ul class="space-y-3 text-white/60 text-sm">
          <li><a href="/programs/btech-ai-ds" class="hover:text-[#f7ba26] transition-colors">B.Tech AI &amp; Data Science</a></li>
          <li><a href="/programs/btech-fintech" class="hover:text-[#f7ba26] transition-colors">B.Tech FinTech &amp; AI</a></li>
          <li><a href="/programs/btech-cyber" class="hover:text-[#f7ba26] transition-colors">B.Tech Cyber Security</a></li>
          <li><a href="/programs/btech-core" class="hover:text-[#f7ba26] transition-colors">B.Tech Core CSE</a></li>
          <li><a href="/programs/btech-ai-ml" class="hover:text-[#f7ba26] transition-colors">B.Tech AI &amp; ML</a></li>
          <li><a href="/programs/btech-biomedical" class="hover:text-[#f7ba26] transition-colors">B.Tech Biomedical Engineering</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-extrabold text-lg mb-6">Quick Links</h4>
        <ul class="space-y-3 text-white/60 text-sm">
          <li><a href="/about" class="hover:text-[#f7ba26] transition-colors">About Us</a></li>
          <li><a href="/campus" class="hover:text-[#f7ba26] transition-colors">Campus Life</a></li>
          <li><a href="/faq" class="hover:text-[#f7ba26] transition-colors">FAQs</a></li>
          <li><a href="/contact" class="hover:text-[#f7ba26] transition-colors">Contact</a></li>
          <li><a href="/playground" class="hover:text-[#f7ba26] transition-colors">Try AI Playground</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-extrabold text-lg mb-6">Contact</h4>
        <ul class="space-y-4 text-white/60 text-sm">
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-[#f7ba26] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498A1 1 0 0121 15.72V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            +91 8688664337
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-[#f7ba26] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            info@iiath.com
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-4 h-4 text-[#f7ba26] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
            iiath.com
          </li>
        </ul>
      </div>
    </div>

    <div class="max-w-7xl mx-auto pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-white/40">
      <p>© {new Date().getFullYear()} IIAT Hyderabad. All rights reserved. Indian Institute of Advanced Technologies.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white">Privacy Policy</a>
        <a href="#" class="hover:text-white">Terms &amp; Conditions</a>
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
    
    // Navbar shadow on scroll
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 10) navbar?.classList.add('shadow-lg');
      else navbar?.classList.remove('shadow-lg');
    });

    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('opacity-100', 'translate-y-0');
          entry.target.classList.remove('opacity-0', 'translate-y-8');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => {
      el.classList.add('opacity-0', 'translate-y-8', 'transition-all', 'duration-700');
      observer.observe(el);
    });
  </script>

</body>
</html>
